---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getPostCategory, groupPostsByCategory } from '../data/categories';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import ProfileImage from '../assets/profile.jpg';

const baseURL = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const categories = groupPostsByCategory(posts);
const latestPost = posts[0];
const topCategories = categories.slice(0, 3).map((item) => item.name).join(' / ') || '持续整理中';
const latestDateLabel = latestPost
	? latestPost.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
	: '待更新';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} image={ProfileImage} />
		<style>
			.about-hero {
				padding: var(--space-5);
			}

			.about-hero {
				display: grid;
				grid-template-columns: minmax(320px, 0.78fr) minmax(0, 1.22fr);
				gap: var(--space-5);
				align-items: start;
				padding-top: var(--space-4);
			}

			.portrait-panel,
			.copy-panel,
			.note-card,
			.info-card {
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
			}

			.portrait-panel {
				padding: 1rem;
				border-radius: var(--radius-xl);
				box-shadow: var(--shadow-sm);
			}

			.portrait-panel :global(img) {
				width: 100%;
				aspect-ratio: 1 / 1.12;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.copy-panel {
				display: grid;
				gap: 0.9rem;
				padding: 1.35rem;
				border-radius: var(--radius-xl);
				box-shadow: var(--shadow-sm);
			}

			.copy-panel h1 {
				max-width: none;
				white-space: nowrap;
				font-size: clamp(2.4rem, 4vw, 3.6rem);
				line-height: 1;
			}

			.copy-panel > p {
				max-width: 36rem;
				font-size: 0.98rem;
			}

			.info-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.info-card,
			.note-card {
				display: grid;
				gap: 0.6rem;
				padding: 0.9rem 1rem;
				border-radius: 12px;
				box-shadow: var(--shadow-sm);
			}

			.info-card span,
			.note-card span {
				font-size: 0.76rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.info-card strong,
			.note-card strong {
				font-size: 1rem;
				line-height: 1.35;
			}

			.meta-strip {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.meta-strip div {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.55rem 0.85rem;
				border-radius: 999px;
				background: var(--nav-bg);
				border: 1px solid var(--line);
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--ink-soft);
			}

			.link-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			.link-row a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				border: 1px solid var(--line);
				background: var(--card-bg-warm);
				font-weight: 700;
				color: var(--ink-soft);
			}

			.link-row a:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.favorite-quote {
				display: grid;
				gap: 0.4rem;
				margin: 0;
				padding: 1.1rem 1.25rem;
				border-left: 3px solid var(--accent-warm);
				border-radius: 0 12px 12px 0;
				background: rgba(226, 168, 111, 0.1);
			}

			.favorite-quote strong {
				font-family: var(--font-display);
				font-size: 1.4rem;
				line-height: 1.1;
				letter-spacing: -0.04em;
				color: var(--accent-strong);
			}

			.favorite-quote cite {
				font-style: normal;
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				color: var(--ink-faint);
			}

			@media (max-width: 960px) {
				.about-hero,
				.info-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.about-hero {
					padding: var(--space-4);
				}

				.copy-panel {
					padding: 1.2rem;
				}

				.copy-panel h1 {
					white-space: normal;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero soft-panel">
				<div class="portrait-panel">
					<Image src={ProfileImage} alt="sonder avatar" width={720} height={808} />
				</div>
				<div class="copy-panel">
					<span class="section-tag">关于我</span>
					<h1>你好，我是 sonder</h1>
					<p>我会把学习、实践和中间的思考过程记下来，让这些内容以后还能继续用。</p>
					<div class="meta-strip">
						<div>{posts.length} 篇文章</div>
						<div>{categories.length} 个主题</div>
						<div>最近更新于 {latestDateLabel}</div>
					</div>
					<p>这里更像一份长期展开的学习档案，重点不是答案本身，而是路径。</p>
					<div class="info-grid">
						<div class="info-card">
							<span>昵称</span>
							<strong>sonder</strong>
							<p>持续学习中的开发者。</p>
						</div>
						<div class="info-card">
							<span>个人主张</span>
							<strong>保持热爱，无限进步</strong>
							<p>长期主义地积累微小改进。</p>
						</div>
						<div class="info-card">
							<span>当前关注</span>
							<strong>{topCategories}</strong>
							<p>持续打磨工程实践与内容表达。</p>
						</div>
						<div class="info-card">
							<span>最近一篇</span>
							<strong>{latestPost?.data.title ?? '新的文章筹备中'}</strong>
							<p>{latestDateLabel}</p>
						</div>
					</div>
					<blockquote class="favorite-quote">
						<strong>"活下去"</strong>
						<cite>宫崎骏《幽灵公主》</cite>
					</blockquote>
					<div class="link-row">
						<a href="mailto:3192422357@qq.com">邮箱</a>
						<a href="https://github.com/Misaka789" target="_blank" rel="noreferrer">GitHub</a>
						<a href={`${baseURL}rss.xml`}>RSS</a>
						<a href={`${baseURL}blog`}>文章归档</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
