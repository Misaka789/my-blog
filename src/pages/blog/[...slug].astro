---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { existsSync, statSync } from 'node:fs';
import { isAbsolute, resolve } from 'node:path';
import BlogPost from '../../layouts/BlogPost.astro';
import { getCategoryMeta, getPostCategory } from '../../data/categories';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const currentPost = getPostCategory(post);
const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const currentIndex = allPosts.findIndex((entry) => entry.id === currentPost.id);
const previousPost = currentIndex >= 0 ? allPosts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const categoryCount = allPosts.filter((entry) => entry.categoryName === currentPost.categoryName).length;
const estimateReadingTime = (content: string) => {
	const cjkCount = (content.match(/[\u4e00-\u9fff]/g) || []).length;
	const latinWordCount = (content.replace(/[\u4e00-\u9fff]/g, ' ').match(/[A-Za-z0-9_]+/g) || []).length;
	return Math.max(1, Math.round(cjkCount / 300 + latinWordCount / 220));
};

const resolvePostFilePath = (filePath?: string) => {
	if (!filePath) return undefined;

	const directPath = isAbsolute(filePath) ? filePath : resolve(filePath);
	if (existsSync(directPath)) return directPath;

	const contentPath = resolve('src/content/blog', filePath);
	if (existsSync(contentPath)) return contentPath;

	return undefined;
};

const isSameCalendarDate = (left: Date, right: Date) =>
	left.getFullYear() === right.getFullYear() &&
	left.getMonth() === right.getMonth() &&
	left.getDate() === right.getDate();

const readingTime = estimateReadingTime(post.body);
const { Content, headings } = await render(post);
const postFilePath = resolvePostFilePath(post.filePath);
const lastModifiedDate = postFilePath ? statSync(postFilePath).mtime : undefined;
const displayUpdatedDate =
	lastModifiedDate && !isSameCalendarDate(lastModifiedDate, post.data.pubDate)
		? lastModifiedDate
		: undefined;
---

<BlogPost
	{...post.data}
	updatedDate={displayUpdatedDate}
	category={currentPost.categoryName}
	categorySummary={getCategoryMeta(currentPost.categoryName, categoryCount).summary}
	headings={headings}
	readingTime={readingTime}
	previousPost={previousPost}
	nextPost={nextPost}
>
	<Content />
</BlogPost>
