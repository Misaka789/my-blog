---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostCategory, groupPostsByCategory, toCategoryId } from '../../data/categories';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const categories = groupPostsByCategory(posts);
const latestPosts = posts.slice(0, 3);
const baseURL = import.meta.env.BASE_URL;
const formatDateTitle = (date: Date) =>
	`发布于 ${date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.search-shell {
				display: grid;
				gap: 0.75rem;
				padding: var(--space-4);
				margin-top: var(--space-3);
			}

			.search-input {
				width: 100%;
				padding: 0.95rem 1rem;
				border: 1px solid var(--line);
				border-radius: 12px;
				background: var(--input-bg);
				color: var(--ink);
				font: inherit;
			}

			.search-input::placeholder {
				color: var(--ink-faint);
			}

			.search-empty {
				display: none;
				padding: var(--space-5) var(--space-4);
				text-align: center;
				color: var(--ink-faint);
				font-size: 0.95rem;
			}

			.category-nav-shell {
				position: sticky;
				top: 5.8rem;
				z-index: 15;
				margin-top: var(--space-3);
				padding: 0.9rem 1rem;
			}

			.category-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.category-nav a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				padding: 0.62rem 0.86rem;
				border-radius: 999px;
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-size: 0.84rem;
				font-weight: 700;
			}

			.category-nav a:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.category-count {
				font-size: 0.8rem;
				color: var(--ink-faint);
			}

			.latest-section {
				display: grid;
				gap: var(--space-3);
				padding: var(--space-5) 0;
				margin-top: var(--space-3);
				border-top: 1px solid var(--line);
			}

			.category-section {
				display: grid;
				gap: var(--space-3);
				padding: var(--space-5) 0;
				border-top: 1px solid var(--line);
				scroll-margin-top: 8rem;
			}

			.section-head {
				display: grid;
				gap: 0.75rem;
			}

			.latest-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.latest-card {
				display: grid;
				gap: 0.75rem;
				padding: 1.2rem;
				border-radius: var(--radius-lg);
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				box-shadow: var(--shadow-sm);
			}

			.latest-card:hover,
			.post-item:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-md);
			}

			.category-head {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: end;
			}

			.category-copy {
				display: grid;
				gap: 0.75rem;
				max-width: 40rem;
			}

			.category-head h2 {
				font-size: clamp(1.8rem, 3vw, 2.45rem);
			}

			.post-count {
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.post-list {
				display: grid;
				gap: var(--space-3);
			}

			.post-item {
				display: grid;
				grid-template-columns: 8.5rem minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: start;
				padding: var(--space-4);
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
			}

			.post-date {
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.post-content {
				display: grid;
				gap: 0.65rem;
			}

			.post-content h3 {
				font-size: clamp(1.35rem, 2vw, 1.8rem);
				line-height: 1.12;
			}

			.post-arrow {
				color: var(--accent-strong);
				font-size: 1.2rem;
				line-height: 1;
			}

			@media (max-width: 720px) {
				.search-shell {
					padding: var(--space-4);
				}

				.latest-section,
				.category-section {
					padding: var(--space-4) 0;
				}

				.latest-grid,
				.category-head,
				.post-item {
					grid-template-columns: 1fr;
				}

				.post-arrow {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="search-shell soft-panel">
				<span class="section-tag">站内搜索</span>
				<input class="search-input" type="search" placeholder="搜索标题、描述或分类" data-search-input />
			</section>

			<section class="category-nav-shell soft-panel">
				<div class="category-nav">
					{categories.map((category) => (
						<a href={`#${toCategoryId(category.name)}`}>
							<span>{category.name}</span>
							<span class="category-count">{category.count} 篇</span>
						</a>
					))}
				</div>
			</section>

			<section class="latest-section">
				<div class="section-head">
					<span class="section-tag">最近更新</span>
					<h2>如果是第一次来，建议先从这里开始</h2>
				</div>
				<div class="latest-grid">
					{latestPosts.map((post) => (
						<a class="latest-card" href={`${baseURL}blog/${post.id}/`} title={formatDateTitle(post.data.pubDate)} data-search-item data-search-text={`${post.data.title} ${post.data.description} ${post.categoryName}`}>
							<span class="eyebrow">{post.categoryName}</span>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
							<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
						</a>
					))}
				</div>
			</section>

			<div class="search-empty" data-search-empty>没有找到匹配的文章，试试其他关键词？</div>

			{categories.map((category) => (
				<section class="category-section" id={toCategoryId(category.name)} data-category-section>
					<div class="category-head">
						<div class="category-copy">
							<span class="section-tag">{category.name}</span>
							<h2>{category.name}</h2>
							<p>{category.summary} {category.readerHint}</p>
						</div>
						<div class="post-count">{category.count} 篇</div>
					</div>
					<div class="post-list">
						{category.posts.map((post) => (
							<a href={`${baseURL}blog/${post.id}/`} class="post-item" title={formatDateTitle(post.data.pubDate)} data-search-item data-search-text={`${post.data.title} ${post.data.description} ${post.categoryName}`}>
								<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
								<div class="post-content">
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
								<div class="post-arrow" aria-hidden="true">↗</div>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
		<script>
			const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
			const items = Array.from(document.querySelectorAll('[data-search-item]')) as HTMLElement[];
			const sections = Array.from(document.querySelectorAll('[data-category-section]')) as HTMLElement[];
			const emptyEl = document.querySelector('[data-search-empty]') as HTMLElement | null;

			let debounceTimer: ReturnType<typeof setTimeout>;

			const updateSearch = () => {
				const query = input?.value.trim().toLowerCase() || '';
				let visibleCount = 0;

				items.forEach((item) => {
					const text = item.getAttribute('data-search-text')?.toLowerCase() || '';
					const match = !query || text.includes(query);
					item.style.display = match ? '' : 'none';
					if (match) visibleCount++;
				});

				sections.forEach((section) => {
					const visible = Array.from(section.querySelectorAll('[data-search-item]')).some(
						(item) => (item as HTMLElement).style.display !== 'none'
					);
					section.style.display = visible || !query ? '' : 'none';
				});

				if (emptyEl) {
					emptyEl.style.display = query && visibleCount === 0 ? 'block' : 'none';
				}
			};

			input?.addEventListener('input', () => {
				clearTimeout(debounceTimer);
				debounceTimer = setTimeout(updateSearch, 200);
			});
		</script>
	</body>
</html>