---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				margin-bottom: 2em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.3em;
			}
			.page-header p {
				font-size: 1.05em;
			}
			.post-list {
				display: flex;
				flex-direction: column;
			}
			.post-item {
				display: block;
				padding: 1.3em 1em;
				margin: 0 -1em;
				border-radius: 10px;
				text-decoration: none;
				transition: background 0.2s ease;
			}
			.post-item:hover {
				background: rgba(255, 255, 255, 0.03);
			}
			.post-item + .post-item {
				border-top: 1px solid var(--border);
			}
			.post-item:hover + .post-item,
			.post-item:has(+ .post-item:hover) {
				border-top-color: transparent;
			}
			.post-title {
				color: var(--text-primary);
				font-weight: 600;
				font-size: 1.15em;
				line-height: 1.4;
				margin-bottom: 0.3em;
				transition: color 0.2s ease;
			}
			.post-item:hover .post-title {
				color: var(--accent);
			}
			.post-desc {
				color: var(--text-muted);
				font-size: 0.92em;
				line-height: 1.5;
				margin-bottom: 0.4em;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-meta {
				color: var(--text-muted);
				font-size: 0.82em;
				font-variant-numeric: tabular-nums;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>技术深度拆解与工程实践复盘</p>
			</div>
			<div class="post-list">
				{posts.map((post) => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="post-item">
						<div class="post-title">{post.data.title}</div>
						<div class="post-desc">{post.data.description}</div>
						<div class="post-meta"><FormattedDate date={post.data.pubDate} /></div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>