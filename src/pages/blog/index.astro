---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryCounts = posts.reduce((map, post) => {
	map.set(post.data.category, (map.get(post.data.category) ?? 0) + 1);
	return map;
}, new Map<string, number>());

const categories = Array.from(categoryCounts.entries())
	.sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'zh-CN'))
	.map(([name, count]) => ({
		name,
		count,
		posts: posts.filter((post) => post.data.category === name),
	}));

const baseURL = import.meta.env.BASE_URL;
const toCategoryId = (category: string) =>
	`category-${category.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fa5-]/g, '')}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-hero {
				padding: 1rem 0 1.8rem;
				display: grid;
				gap: 1rem;
			}

			.archive-hero p {
				max-width: 44rem;
				font-size: 1.04rem;
			}

			.category-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
			}

			.category-nav a,
			.post-category {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				width: fit-content;
				padding: 0.82rem 1.06rem;
				border-radius: 999px;
				background: rgba(248, 253, 249, 0.88);
				border: 1px solid rgba(103, 129, 114, 0.15);
				color: var(--ink-soft);
				font-size: 0.94rem;
				font-weight: 700;
				box-shadow: var(--shadow-sm);
			}

			.category-nav a:hover {
				transform: translateY(-2px);
				background: white;
			}

			.category-count {
				font-size: 0.84rem;
				color: var(--ink-faint);
			}

			.category-section {
				padding: 1.7rem;
				margin-top: 1rem;
			}

			.category-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.category-head h2 {
				font-size: clamp(1.8rem, 3vw, 2.8rem);
			}

			.post-list {
				display: grid;
				gap: 1rem;
			}

			.post-item {
				display: grid;
				grid-template-columns: 9rem minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: start;
				padding: 1.4rem 1.45rem;
				background: rgba(248, 253, 249, 0.88);
				border: 1px solid rgba(103, 129, 114, 0.15);
				border-radius: var(--radius-xl);
				box-shadow: var(--shadow-sm);
			}

			.post-item:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-md);
				background: white;
			}

			.post-date {
				font-size: 0.88rem;
				font-weight: 700;
				letter-spacing: 0.04em;
				color: var(--ink-faint);
			}

			.post-content {
				display: grid;
				gap: 0.55rem;
			}

			.post-content h3 {
				font-size: clamp(1.5rem, 2vw, 2rem);
				line-height: 1.1;
			}

			.post-arrow {
				color: var(--accent);
				font-size: 1.5rem;
				line-height: 1;
			}

			@media (max-width: 720px) {
				.category-section {
					padding: 1.2rem;
				}

				.category-head,
				.post-item {
					grid-template-columns: 1fr;
				}

				.post-arrow {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-hero">
				<span class="section-tag">分类归档</span>
				<h1>按主题整理的文章</h1>
				<p>如果你是带着某个问题来的，可以直接从分类进入；如果只是随便看看，也能很快知道这里主要在写什么。</p>
				<div class="category-nav">
					{categories.map((category) => (
						<a href={`#${toCategoryId(category.name)}`}>
							<span>{category.name}</span>
							<span class="category-count">{category.count} 篇</span>
						</a>
					))}
				</div>
			</section>

			{categories.map((category) => (
				<section class="category-section soft-panel" id={toCategoryId(category.name)}>
					<div class="category-head">
						<h2>{category.name}</h2>
						<div class="post-category">{category.count} 篇文章</div>
					</div>
					<div class="post-list">
						{category.posts.map((post) => (
							<a href={`${baseURL}blog/${post.id}/`} class="post-item">
								<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
								<div class="post-content">
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
								<div class="post-arrow" aria-hidden="true">↗</div>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
