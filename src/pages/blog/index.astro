---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostCategory, groupPostsByCategory, toCategoryId } from '../../data/categories';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const categories = groupPostsByCategory(posts);
const baseURL = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-hero,
			.category-nav-shell,
			.category-section {
				padding: var(--space-5);
			}

			.archive-hero {
				display: grid;
				gap: var(--space-2);
				padding-top: var(--space-4);
			}

			.archive-hero p {
				max-width: 44rem;
			}

			.category-nav-shell {
				position: sticky;
				top: 5.8rem;
				z-index: 15;
				margin-top: var(--space-3);
			}

			.category-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.category-nav a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				padding: 0.7rem 0.95rem;
				border-radius: 999px;
				background: #fff;
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-size: 0.88rem;
				font-weight: 700;
				transition: all var(--transition);
			}

			.category-nav a:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.category-count {
				font-size: 0.8rem;
				color: var(--ink-faint);
			}

			.category-section {
				display: grid;
				gap: var(--space-3);
				margin-top: var(--space-3);
				scroll-margin-top: 8rem;
			}

			.category-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: var(--space-2);
			}

			.category-head h2 {
				font-size: clamp(1.8rem, 3vw, 2.45rem);
			}

			.post-count {
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.post-list {
				display: grid;
				gap: var(--space-3);
			}

			.post-item {
				display: grid;
				grid-template-columns: 8.5rem minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: start;
				padding: var(--space-4);
				background: var(--paper-strong);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
				transition: all var(--transition);
			}

			.post-item:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}

			.post-date {
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.post-content {
				display: grid;
				gap: 0.65rem;
			}

			.post-content h3 {
				font-size: clamp(1.35rem, 2vw, 1.8rem);
				line-height: 1.12;
			}

			.post-arrow {
				color: var(--accent-strong);
				font-size: 1.2rem;
				line-height: 1;
			}

			@media (max-width: 720px) {
				.archive-hero,
				.category-nav-shell,
				.category-section {
					padding: var(--space-4);
				}

				.category-head,
				.post-item {
					grid-template-columns: 1fr;
				}

				.post-arrow {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-hero soft-panel">
				<span class="section-tag">文章归档</span>
				<h1>文章档案</h1>
				<p>你可以先按主题快速定位，再直接进入文章列表开始阅读。</p>
			</section>

			<section class="category-nav-shell soft-panel">
				<div class="category-nav">
					{categories.map((category) => (
						<a href={`#${toCategoryId(category.name)}`}>
							<span>{category.name}</span>
							<span class="category-count">{category.count} 篇</span>
						</a>
					))}
				</div>
			</section>

			{categories.map((category) => (
				<section class="category-section soft-panel" id={toCategoryId(category.name)}>
					<div class="category-head">
						<h2>{category.name}</h2>
						<div class="post-count">{category.count} 篇</div>
					</div>
					<div class="post-list">
						{category.posts.map((post) => (
							<a href={`${baseURL}blog/${post.id}/`} class="post-item">
								<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
								<div class="post-content">
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
								<div class="post-arrow" aria-hidden="true">↗</div>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
