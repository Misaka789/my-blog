---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostCategory, groupPostsByCategory, toCategoryId } from '../../data/categories';

const posts = (await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const categories = groupPostsByCategory(posts);
const latestPosts = posts.slice(0, 3);
const baseURL = import.meta.env.BASE_URL;
const formatDateTitle = (date: Date) =>
	`发布于 ${date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.search-shell {
				display: grid;
				gap: 0.75rem;
				padding: var(--space-4);
				margin-top: var(--space-3);
			}

			.search-input {
				width: 100%;
				padding: 0.95rem 1rem;
				border: 1px solid var(--line);
				border-radius: 12px;
				background: var(--input-bg);
				color: var(--ink);
				font: inherit;
			}

			.search-input::placeholder {
				color: var(--ink-faint);
			}

			.search-empty {
				display: none;
				padding: var(--space-5) var(--space-4);
				text-align: center;
				color: var(--ink-faint);
				font-size: 0.95rem;
			}

			.archive-section {
				display: grid;
				gap: var(--space-3);
				margin-top: var(--space-3);
				padding: var(--space-5) 0;
				border-top: 1px solid var(--line);
				scroll-margin-top: 8rem;
			}

			.archive-summary {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: center;
				cursor: pointer;
				list-style: none;
			}

			.archive-summary::-webkit-details-marker {
				display: none;
			}

			.archive-summary-copy {
				display: grid;
				gap: 0.75rem;
			}

			.archive-summary h2 {
				font-size: clamp(1.8rem, 3vw, 2.45rem);
			}

			.archive-toggle {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 4.5rem;
				padding: 0.62rem 0.86rem;
				border-radius: 999px;
				background: rgba(255, 252, 247, 0.78);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-size: 0.84rem;
				font-weight: 700;
			}

			.archive-toggle::after {
				content: "展开";
			}

			.archive-section[open] .archive-toggle::after {
				content: "收起";
			}

			.archive-content {
				display: grid;
				gap: var(--space-3);
				margin-top: var(--space-3);
			}

			.category-nav-shell {
				padding: 0.9rem 1rem;
			}

			.category-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.category-nav a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				padding: 0.62rem 0.86rem;
				border-radius: 999px;
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-size: 0.84rem;
				font-weight: 700;
			}

			.category-nav a:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.category-count {
				font-size: 0.8rem;
				color: var(--ink-faint);
			}

			.latest-section {
				display: grid;
				gap: var(--space-3);
				padding: var(--space-5) 0;
				margin-top: var(--space-3);
				border-top: 1px solid var(--line);
			}

			.category-section {
				display: grid;
				gap: var(--space-3);
				padding: var(--space-5) 0;
				border-top: 1px solid var(--line);
				scroll-margin-top: 8rem;
			}

			.section-head {
				display: grid;
				gap: 0.75rem;
			}

			.latest-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.latest-card {
				display: grid;
				gap: 0.75rem;
				padding: 1.2rem;
				border-radius: var(--radius-lg);
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				box-shadow: var(--shadow-sm);
			}

			.latest-card:hover,
			.post-item:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-md);
			}

			.category-head {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: end;
				cursor: pointer;
				list-style: none;
			}

			.category-head::-webkit-details-marker {
				display: none;
			}

			.category-copy {
				display: grid;
				gap: 0.75rem;
				max-width: 40rem;
			}

			.category-head h2 {
				font-size: clamp(1.8rem, 3vw, 2.45rem);
			}

			.post-count {
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.category-toggle {
				display: inline-flex;
				align-items: center;
				gap: 0.65rem;
				color: var(--ink-faint);
				font-size: 0.84rem;
				font-weight: 700;
			}

			.category-toggle::after {
				content: "展开";
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 3rem;
				padding: 0.52rem 0.72rem;
				border-radius: 999px;
				background: rgba(255, 252, 247, 0.78);
				border: 1px solid var(--line);
				color: var(--ink-soft);
			}

			.category-section[open] .category-toggle::after {
				content: "收起";
			}

			.post-list {
				display: grid;
				gap: var(--space-3);
				margin-top: var(--space-3);
			}

			.post-item {
				display: grid;
				grid-template-columns: 8.5rem minmax(0, 1fr) auto;
				gap: var(--space-3);
				align-items: start;
				padding: var(--space-4);
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
			}

			.post-date {
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.series-badge {
				display: inline-block;
				margin-left: 0.5rem;
				padding: 0.1rem 0.45rem;
				border-radius: 999px;
				background: var(--accent);
				color: white;
				font-size: 0.72rem;
				font-weight: 600;
				vertical-align: middle;
			}

			.post-content {
				display: grid;
				gap: 0.65rem;
			}

			.post-content h3 {
				font-size: clamp(1.35rem, 2vw, 1.8rem);
				line-height: 1.12;
			}

			.post-arrow {
				color: var(--accent-strong);
				font-size: 1.2rem;
				line-height: 1;
			}

			@media (max-width: 720px) {
				.search-shell {
					padding: var(--space-4);
				}

				.latest-section,
				.archive-section,
				.category-section {
					padding: var(--space-4) 0;
				}

				.latest-grid,
				.archive-summary,
				.category-head,
				.post-item {
					grid-template-columns: 1fr;
				}

				.post-arrow {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="search-shell soft-panel">
				<span class="section-tag">站内搜索</span>
				<input class="search-input" type="search" placeholder="搜索标题、描述或分类" data-search-input />
			</section>

			<section class="latest-section">
				<div class="section-head">
					<span class="section-tag">最近更新</span>
					<h2>最新文章</h2>
				</div>
				<div class="latest-grid">
					{latestPosts.map((post) => (
						<a class="latest-card" href={`${baseURL}blog/${post.id}/`} title={formatDateTitle(post.data.pubDate)} data-search-item data-search-text={`${post.data.title} ${post.data.description} ${post.categoryName}`}>
							<span class="eyebrow">{post.categoryName}</span>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
							<div class="post-date"><FormattedDate date={post.data.pubDate} /> · {post.readingTime} 分钟</div>
						</a>
					))}
				</div>
			</section>

			<div class="search-empty" data-search-empty>没有找到匹配的文章，试试其他关键词？</div>

			<details class="archive-section soft-panel" data-archive-section>
				<summary class="archive-summary">
					<div class="archive-summary-copy">
						<span class="section-tag">分类归档</span>
						<h2>按主题浏览</h2>
						<p>{categories.length} 个主题，{posts.length} 篇文章。</p>
					</div>
					<span class="archive-toggle" aria-hidden="true"></span>
				</summary>
				<div class="archive-content">
					<section class="category-nav-shell">
						<div class="category-nav">
							{categories.map((category) => (
								<a href={`#${toCategoryId(category.name)}`} data-category-nav-link={toCategoryId(category.name)}>
									<span>{category.name}</span>
									<span class="category-count">{category.count} 篇</span>
								</a>
							))}
						</div>
					</section>

						{categories.map((category) => (
							<details class="category-section" id={toCategoryId(category.name)} data-category-section>
								<summary class="category-head">
									<div class="category-copy">
										<span class="section-tag">{category.name}</span>
										<h2>{category.name}</h2>
										<p>{category.summary}</p>
									</div>
									<div class="category-toggle">
										<span class="post-count">{category.count} 篇</span>
								</div>
							</summary>
								<div class="post-list">
									{category.posts.map((post) => (
										<a href={`${baseURL}blog/${post.id}/`} class="post-item" title={formatDateTitle(post.data.pubDate)} data-search-item data-search-text={`${post.data.title} ${post.data.description} ${post.categoryName}`}>
											<div class="post-date"><FormattedDate date={post.data.pubDate} /> · {post.readingTime} 分钟{post.data.series && <span class="series-badge">📚 {post.data.series}</span>}</div>
											<div class="post-content">
												<h3>{post.data.title}</h3>
												<p>{post.data.description}</p>
										</div>
										<div class="post-arrow" aria-hidden="true">↗</div>
									</a>
								))}
							</div>
						</details>
					))}
				</div>
			</details>
		</main>
		<Footer />
		<script>
			const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
			const items = Array.from(document.querySelectorAll('[data-search-item]')) as HTMLElement[];
			const sections = Array.from(document.querySelectorAll('[data-category-section]')) as HTMLDetailsElement[];
			const emptyEl = document.querySelector('[data-search-empty]') as HTMLElement | null;
			const archive = document.querySelector('[data-archive-section]') as HTMLDetailsElement | null;

			let debounceTimer: ReturnType<typeof setTimeout>;

			const updateSearch = () => {
				const query = input?.value.trim().toLowerCase() || '';
				let visibleCount = 0;

				items.forEach((item) => {
					const text = item.getAttribute('data-search-text')?.toLowerCase() || '';
					const match = !query || text.includes(query);
					item.style.display = match ? '' : 'none';
					if (match) visibleCount++;
				});

				sections.forEach((section) => {
					const visible = Array.from(section.querySelectorAll('[data-search-item]')).some(
						(item) => (item as HTMLElement).style.display !== 'none'
					);
					section.style.display = visible || !query ? '' : 'none';
					section.open = query ? visible : false;
				});

				if (archive) {
					archive.open = Boolean(query);
				}

				if (emptyEl) {
					emptyEl.style.display = query && visibleCount === 0 ? 'block' : 'none';
				}
			};

			input?.addEventListener('input', () => {
					clearTimeout(debounceTimer);
					debounceTimer = setTimeout(updateSearch, 200);
				});

			const openHashCategory = () => {
				const id = window.location.hash.slice(1);
				if (!id) return;
				const section = document.getElementById(id) as HTMLDetailsElement | null;
				if (!section?.matches('[data-category-section]')) return;
				if (archive) archive.open = true;
				section.open = true;
			};

			document.querySelectorAll('[data-category-nav-link]').forEach((link) => {
				link.addEventListener('click', () => {
					const id = link.getAttribute('data-category-nav-link');
					const section = id ? document.getElementById(id) as HTMLDetailsElement | null : null;
					if (section) section.open = true;
				});
			});

			openHashCategory();
			window.addEventListener('hashchange', openHashCategory);
		</script>
	</body>
</html>
