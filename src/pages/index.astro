---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPostCategory } from '../data/categories';
import HeroImage from '../assets/spirited-princess.jpg';

const baseURL = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const fromHereHref = posts[0] ? `${baseURL}blog/${posts[0].id}/` : `${baseURL}blog`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={HeroImage} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
				gap: var(--space-5);
				align-items: start;
				padding: var(--space-5);
				padding-top: var(--space-4);
			}

			.hero-left {
				display: grid;
				gap: var(--space-4);
			}

			.hero-left h1 {
				max-width: 16ch;
				font-size: clamp(2.05rem, 3.2vw, 3rem);
				line-height: 1.18;
				letter-spacing: -0.03em;
			}

			.hero-left p {
				max-width: 34rem;
				font-size: 1rem;
				color: var(--ink-soft);
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			.hero-actions a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.84rem 1.1rem;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid var(--line);
				background: #fff;
				transition: all var(--transition);
			}

			.hero-actions a.primary {
				background: var(--accent);
				color: #fff;
				border-color: transparent;
			}

			.hero-actions a:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
			}

			.directory {
				display: grid;
				gap: var(--space-3);
				padding: var(--space-4);
				border-radius: var(--radius-lg);
				background: var(--paper-strong);
				border: 1px solid var(--line);
			}

			.directory h2 {
				font-size: 1.2rem;
				letter-spacing: -0.01em;
			}

			.directory-list {
				display: grid;
				gap: 0.7rem;
			}

			.directory-item {
				display: grid;
				grid-template-columns: auto 1fr auto;
				align-items: center;
				gap: 0.65rem;
				padding: 0.7rem 0.8rem;
				border-radius: var(--radius-md);
				border: 1px solid transparent;
			}

			.directory-item:hover {
				background: #fff;
				border-color: var(--line);
				box-shadow: var(--shadow-sm);
				transform: translateY(-1px);
			}

			.order {
				font-size: 0.76rem;
				color: var(--ink-faint);
				font-weight: 700;
				letter-spacing: 0.08em;
			}

			.title {
				font-weight: 700;
				color: var(--ink);
				line-height: 1.35;
			}

			.date {
				font-size: 0.84rem;
				color: var(--ink-faint);
				font-weight: 600;
				white-space: nowrap;
			}

			.hero-right {
				display: grid;
				gap: 0.7rem;
			}

			.hero-right :global(img) {
				width: 100%;
				aspect-ratio: 1 / 1.03;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.caption {
				font-size: 0.9rem;
				color: var(--ink-faint);
			}

			@media (max-width: 960px) {
				.hero {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.hero {
					padding: var(--space-4);
				}

				.directory-item {
					grid-template-columns: auto 1fr;
				}

				.date {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero soft-panel">
				<div class="hero-left">
					<span class="section-tag">写给正在学习的你</span>
					<h1>重要的不是立刻有答案，而是把每一步思考写清楚。</h1>
					<p>这里是一份持续更新的学习档案，重点放在真实过程和可复用经验。</p>
					<div class="hero-actions">
						<a class="primary" href={fromHereHref}>从这里开始</a>
						<a href={`${baseURL}blog`}>浏览文章目录</a>
						<a href={`${baseURL}about`}>关于我</a>
					</div>

					<div class="directory">
						<h2>文章目录</h2>
						<div class="directory-list">
							{posts.map((post, index) => (
								<a class="directory-item" href={`${baseURL}blog/${post.id}/`}>
									<span class="order">{String(index + 1).padStart(2, '0')}</span>
									<span class="title">{post.data.title}</span>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							))}
						</div>
					</div>
				</div>

				<aside class="hero-right">
					<Image src={HeroImage} alt="幽灵公主主题图" width={1200} height={1200} />
					<p class="caption">“活下去。” —— 宫崎骏《幽灵公主》</p>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>
