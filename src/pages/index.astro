---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeroImage from '../assets/spirited-princess.jpg';

const baseURL = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts[0];
const recentPosts = posts.slice(1, 4);

const categoryCounts = posts.reduce((map, post) => {
	map.set(post.data.category, (map.get(post.data.category) ?? 0) + 1);
	return map;
}, new Map<string, number>());

const categories = Array.from(categoryCounts.entries())
	.sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'zh-CN'))
	.map(([name, count]) => ({ name, count }));

const toCategoryId = (category: string) =>
	`category-${category.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fa5-]/g, '')}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={HeroImage} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
				gap: 1.8rem;
				align-items: center;
				padding: 1.25rem 0 2.3rem;
			}

			.hero-copy {
				display: grid;
				gap: 1.15rem;
				padding: 0.35rem 0;
			}

			.hero-copy h1 {
				max-width: 11ch;
				font-size: clamp(2.55rem, 5vw, 4.1rem);
				line-height: 1.12;
				letter-spacing: -0.05em;
			}

			.hero-copy p {
				max-width: 36rem;
				font-size: 1.03rem;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.85rem;
			}

			.hero-actions a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.98rem 1.35rem;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid transparent;
				box-shadow: var(--shadow-sm);
			}

			.hero-actions .primary {
				background: var(--accent);
				color: white;
				box-shadow: 0 16px 35px rgba(105, 138, 120, 0.2);
			}

			.hero-actions .secondary {
				background: rgba(252, 255, 253, 0.88);
				border-color: rgba(103, 129, 114, 0.16);
			}

			.hero-actions a:hover {
				transform: translateY(-2px);
			}

			.quick-facts {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.9rem;
			}

			.quick-facts div {
				padding: 1.05rem 1.15rem;
				border-radius: 999px;
				background: rgba(248, 253, 249, 0.9);
				border: 1px solid rgba(103, 129, 114, 0.13);
				box-shadow: var(--shadow-sm);
			}

			.quick-facts dt {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
				margin-bottom: 0.35rem;
			}

			.quick-facts dd {
				margin: 0;
				font-size: 1rem;
				font-weight: 600;
				color: var(--ink);
			}

			.hero-visual {
				padding: 1.1rem;
				display: grid;
				gap: 0.95rem;
			}

			.hero-visual :global(img) {
				aspect-ratio: 1 / 1;
				width: 100%;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.visual-copy {
				display: grid;
				gap: 0.65rem;
				padding: 0.35rem 0.25rem 0.45rem;
			}

			.visual-copy h2 {
				font-size: clamp(1.8rem, 3vw, 2.5rem);
			}

			.visual-tag {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: fit-content;
				padding: 0.76rem 1rem;
				border-radius: 999px;
				background: rgba(105, 138, 120, 0.12);
				border: 1px solid rgba(103, 129, 114, 0.12);
				color: var(--accent-strong);
				font-weight: 700;
			}

			.section-head {
				display: grid;
				gap: 0.8rem;
				margin-bottom: 1.4rem;
			}

			.category-section,
			.feature-section,
			.focus-section {
				padding: 1.8rem;
				margin-top: 1rem;
			}

			.category-pills {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
			}

			.category-pills a,
			.post-category {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				width: fit-content;
				padding: 0.82rem 1.05rem;
				border-radius: 999px;
				background: rgba(248, 253, 249, 0.88);
				border: 1px solid rgba(103, 129, 114, 0.15);
				color: var(--ink-soft);
				font-size: 0.94rem;
				font-weight: 700;
				box-shadow: var(--shadow-sm);
			}

			.category-pills a:hover {
				transform: translateY(-2px);
				background: white;
			}

			.category-count {
				color: var(--ink-faint);
				font-size: 0.86rem;
			}

			.feature-layout {
				display: grid;
				grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
				gap: 1rem;
			}

			.featured-post {
				display: grid;
				gap: 0.9rem;
				padding: 1.5rem;
				background: linear-gradient(135deg, rgba(250, 255, 251, 0.88), rgba(231, 242, 235, 0.96));
			}

			.featured-post h3 {
				font-size: clamp(1.6rem, 2.4vw, 2.5rem);
				line-height: 1.06;
			}

			.post-meta {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.86rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--ink-faint);
			}

			.post-meta::before {
				content: "";
				width: 0.45rem;
				height: 0.45rem;
				border-radius: 999px;
				background: var(--accent-warm);
			}

			.side-posts {
				display: grid;
				gap: 0.9rem;
			}

			.side-posts a {
				display: grid;
				gap: 0.55rem;
				padding: 1.15rem 1.2rem;
				background: rgba(250, 255, 251, 0.84);
				border: 1px solid rgba(103, 129, 114, 0.13);
				border-radius: var(--radius-lg);
			}

			.side-posts a:hover,
			.featured-post:hover,
			.focus-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-md);
			}

			.side-posts h3 {
				font-size: 1.25rem;
				line-height: 1.2;
			}

			.focus-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}

			.focus-card {
				padding: 1.3rem;
				display: grid;
				gap: 0.7rem;
			}

			.focus-card:nth-child(1) {
				background: linear-gradient(180deg, rgba(250, 255, 251, 0.84), rgba(231, 242, 235, 0.98));
			}

			.focus-card:nth-child(2) {
				background: linear-gradient(180deg, rgba(250, 255, 251, 0.84), rgba(241, 238, 225, 0.98));
			}

			.focus-card:nth-child(3) {
				background: linear-gradient(180deg, rgba(250, 255, 251, 0.84), rgba(238, 244, 241, 0.96));
			}

			.focus-card span {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}

			@media (max-width: 960px) {
				.hero,
				.feature-layout,
				.focus-grid {
					grid-template-columns: 1fr;
				}

				.hero-copy h1 {
					max-width: none;
				}
			}

			@media (max-width: 720px) {
				.category-section,
				.feature-section,
				.focus-section {
					padding: 1.2rem;
				}

				.quick-facts {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<span class="section-tag">写给正在学习的你</span>
					<h1>把学习过程写下来，也把思考慢慢整理清楚。</h1>
					<p>
						这里是 <strong>sonder</strong> 的个人学习博客。它会把编程学习里的理解变化、实践记录和阶段复盘慢慢写下来。
						如果你也正走在学习的路上，希望这里能给你一些具体经验，也给你一点继续往前走的耐心。
					</p>
					<div class="hero-actions">
						<a class="primary" href={`${baseURL}blog`}>进入文章归档</a>
						<a class="secondary" href={`${baseURL}about`}>关于我</a>
					</div>
					<dl class="quick-facts">
						<div>
							<dt>昵称</dt>
							<dd>sonder</dd>
						</div>
						<div>
							<dt>一句话</dt>
							<dd>保持热爱，无限进步</dd>
						</div>
						<div>
							<dt>内容方向</dt>
							<dd>记录学习过程与代码实践</dd>
						</div>
						<div>
							<dt>已发布</dt>
							<dd>{posts.length} 篇文章</dd>
						</div>
					</dl>
				</div>

				<aside class="hero-visual soft-panel">
					<Image src={HeroImage} alt="幽灵公主主题图" width={1200} height={1200} />
					<div class="visual-copy">
						<p class="eyebrow">首页的一点偏爱</p>
						<h2>幽灵公主</h2>
						<p>我把《幽灵公主》放在这里，是想给这个首页留一点安静但坚定的气质。学习很多时候并不轰烈，更像是慢慢积累、一步一步往前走。</p>
						<div class="visual-tag">继续往前走</div>
					</div>
				</aside>
			</section>

			<section class="category-section soft-panel">
				<div class="section-head">
					<span class="section-tag">分类浏览</span>
					<h2>按主题找文章</h2>
					<p>如果你是带着某个问题进来的，可以先从分类开始。这样会比一篇篇往下翻更快，也更适合后面内容慢慢变多。</p>
				</div>
				<div class="category-pills">
					{categories.map((category) => (
						<a href={`${baseURL}blog#${toCategoryId(category.name)}`}>
							<span>{category.name}</span>
							<span class="category-count">{category.count} 篇</span>
						</a>
					))}
				</div>
			</section>

			<section class="feature-section soft-panel">
				<div class="section-head">
					<span class="section-tag">最近更新</span>
					<h2>第一次来，可以先看这里</h2>
					<p>我把最近写的内容放在前面。它们更接近我现在的学习节奏，也更能代表这个博客正在慢慢形成的方向。</p>
				</div>
				<div class="feature-layout">
					{featuredPost && (
						<a class="featured-post card" href={`${baseURL}blog/${featuredPost.id}/`}>
							<div class="post-meta"><FormattedDate date={featuredPost.data.pubDate} /></div>
							<div class="post-category">{featuredPost.data.category}</div>
							<h3>{featuredPost.data.title}</h3>
							<p>{featuredPost.data.description}</p>
						</a>
					)}
					<div class="side-posts">
						{recentPosts.map((post) => (
							<a href={`${baseURL}blog/${post.id}/`}>
								<div class="post-meta"><FormattedDate date={post.data.pubDate} /></div>
								<div class="post-category">{post.data.category}</div>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="focus-section soft-panel">
				<div class="section-head">
					<span class="section-tag">长期更新的内容</span>
					<h2>我会持续写这些主题</h2>
				</div>
				<div class="focus-grid">
					<div class="focus-card card">
						<span>学习记录</span>
						<h3>把学习过程留下来</h3>
						<p>从一个知识点听懂，到自己真正能讲清楚，中间的过程值得被记录。</p>
					</div>
					<div class="focus-card card">
						<span>实践复盘</span>
						<h3>把踩坑和实践写清楚</h3>
						<p>不仅写结果，也写中间卡住的地方、查资料的路径，以及最后为什么这样做。</p>
					</div>
					<div class="focus-card card">
						<span>阶段思考</span>
						<h3>把成长变化慢慢看见</h3>
						<p>一段时间后回头看，博客能帮我看到自己哪里真的进步了，哪里还没学透。</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
