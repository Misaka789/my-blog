---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPostCategory, groupPostsByCategory, toCategoryId } from '../data/categories';
import HeroImage from '../assets/spirited-princess.jpg';

const baseURL = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map(getPostCategory);
const featuredPost = posts[0];
const recentPosts = posts.slice(1, 3);
const categories = groupPostsByCategory(posts).slice(0, 2);
const fromHereHref = featuredPost ? `${baseURL}blog/${featuredPost.id}/` : `${baseURL}blog`;
const formatDateTitle = (date: Date) =>
	`发布于 ${date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={HeroImage} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 0.55fr) minmax(280px, 0.45fr);
				gap: var(--space-5);
				align-items: stretch;
				padding: var(--space-5);
				overflow: hidden;
			}

			.hero-left {
				display: grid;
				gap: var(--space-4);
				align-content: start;
			}

			.hero-intro {
				display: grid;
				gap: 0.95rem;
				max-width: 31rem;
			}

			.hero-kicker {
				display: inline-flex;
				align-items: center;
				gap: 0.8rem;
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--ink-faint);
			}

			.hero-kicker::before {
				content: "";
				width: 2.8rem;
				height: 1px;
				background: linear-gradient(90deg, var(--accent), transparent);
			}

			.hero-intro h1 {
				max-width: 9ch;
				font-size: clamp(3rem, 5vw, 4.8rem);
				line-height: 0.98;
				letter-spacing: -0.06em;
			}

			.hero-intro h1 span {
				display: block;
				color: var(--accent-strong);
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			.hero-actions a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.84rem 1.08rem;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid var(--line);
				background: var(--card-bg-warm);
			}

			.hero-actions a.primary {
				background: var(--accent);
				color: white;
				border-color: transparent;
			}

			.hero-actions a:hover,
			.post-card:hover,
			.category-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
			}

			.hero-right {
				display: grid;
				gap: 1.1rem;
				align-self: stretch;
			}

			.feature-card {
				display: grid;
				grid-template-rows: auto;
				padding: 1.1rem;
				background: var(--feature-card-bg);
				border: 1px solid var(--line);
				border-radius: var(--radius-xl);
				box-shadow: var(--shadow-sm);
			}

			.feature-card :global(img) {
				width: 100%;
				aspect-ratio: 1 / 0.96;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			/* Feed & categories sections - lighter style without soft-panel */
			.feed-section,
			.categories-section {
				display: grid;
				gap: var(--space-4);
				margin-top: var(--space-5);
				padding: var(--space-5) 0;
				border-top: 1px solid var(--line);
			}

			.section-head {
				display: grid;
				gap: 0.8rem;
			}

			.feed-grid,
			.categories-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.post-card,
			.category-card {
				display: grid;
				gap: 0.8rem;
				padding: 1.1rem;
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
			}

			.post-card-top,
			.category-card-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.8rem;
				flex-wrap: wrap;
			}

			.post-card h3,
			.category-card h3 {
				line-height: 1.14;
			}

			.post-card p,
			.category-card p {
				font-size: 0.95rem;
			}

			.category-card strong {
				font-size: 1rem;
			}

			.category-link {
				display: inline-flex;
				align-items: center;
				width: fit-content;
				font-weight: 700;
				color: var(--accent-strong);
			}

			@media (max-width: 960px) {
				.hero,
				.feed-grid,
				.categories-grid {
					grid-template-columns: 1fr;
				}

				.hero-intro h1 {
					max-width: 10ch;
				}
			}

			@media (max-width: 720px) {
				.hero {
					padding: var(--space-4);
				}

				.feed-section,
				.categories-section {
					padding: var(--space-4) 0;
				}

				.feature-card :global(img) {
					aspect-ratio: 16 / 9;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero soft-panel">
				<div class="hero-left">
					<div class="hero-intro">
						<div class="hero-kicker">A Learning Journal</div>
						<h1>把思考写下来<span>让成长留下痕迹</span></h1>
						<div class="hero-actions">
							<a class="primary" href={fromHereHref}>从推荐文章开始</a>
							<a href={`${baseURL}blog`}>浏览全部文章</a>
						</div>
					</div>
				</div>

				<aside class="hero-right">
					<div class="feature-card">
						<Image src={HeroImage} alt="幽灵公主主题图" width={1200} height={980} />
					</div>
				</aside>
			</section>

			<section class="feed-section">
				<div class="section-head">
					<span class="section-tag">最近更新</span>
					<h2>最近写的两篇</h2>
				</div>
				<div class="feed-grid">
					{recentPosts.map((post) => (
						<a class="post-card" href={`${baseURL}blog/${post.id}/`} title={formatDateTitle(post.data.pubDate)}>
							<div class="post-card-top">
								<span class="eyebrow">{post.categoryName}</span>
								<span class="muted"><FormattedDate date={post.data.pubDate} /></span>
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="categories-section">
				<div class="section-head">
					<span class="section-tag">主题浏览</span>
					<h2>从主题开始阅读</h2>
				</div>
				<div class="categories-grid">
					{categories.map((category) => (
						<a class="category-card" href={`${baseURL}blog#${toCategoryId(category.name)}`} title={category.latest ? formatDateTitle(category.latest.data.pubDate) : undefined}>
							<div class="category-card-top">
								<span class="eyebrow">{category.name}</span>
								<span class="muted">{category.count} 篇</span>
							</div>
							<strong>{category.latest?.data.title ?? '持续整理中'}</strong>
							<p>{category.summary}</p>
							<span class="category-link">进入这个主题</span>
						</a>
					))}
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>