---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ProfileImage from '../assets/profile.jpg';

const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="shell header-shell">
		<a href={baseURL} class="identity">
			<Image src={ProfileImage} alt="sonder avatar" width={56} height={56} />
			<div class="identity-copy">
				<span class="eyebrow">Sonder's Notes</span>
				<strong>{SITE_TITLE}</strong>
			</div>
		</a>
		<div class="header-extras">
			<slot />
		</div>
		<nav class="nav-links" aria-label="Primary">
			<HeaderLink href={baseURL}>首页</HeaderLink>
			<HeaderLink href={`${baseURL}blog`}>文章</HeaderLink>
			<HeaderLink href={`${baseURL}about`}>关于</HeaderLink>
			<button type="button" class="theme-toggle" aria-label="切换明暗主题" aria-pressed="false" data-theme-toggle>
				<span class="theme-toggle-track" aria-hidden="true">
					<span class="theme-toggle-sun">☼</span>
					<span class="theme-toggle-moon">☾</span>
					<span class="theme-toggle-thumb"></span>
				</span>
			</button>
		</nav>
	</div>
</header>

<div class="toast-region" aria-live="polite" aria-atomic="true" data-toast-region></div>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		background: linear-gradient(180deg, rgba(251, 248, 242, 0.96), rgba(251, 248, 242, 0.72), transparent);
		backdrop-filter: blur(14px);
	}

	.header-shell {
		min-height: 74px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.65rem 0.85rem;
		border-radius: 999px;
		background: rgba(255, 252, 247, 0.84);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-sm);
	}

	.header-extras {
		flex: 1;
		min-width: 0;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}

	.identity {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
		padding: 0.3rem 0.45rem;
		border-radius: 999px;
	}

	.identity :global(img) {
		width: 3.3rem;
		height: 3.3rem;
		border-radius: 999px;
		object-fit: cover;
		box-shadow: 0 8px 22px rgba(43, 38, 30, 0.12);
	}

	.identity-copy {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.identity-copy strong {
		font-family: var(--font-display);
		font-size: 1.25rem;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	.identity-copy .eyebrow {
		font-size: 0.7rem;
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		padding: 0.24rem;
		border-radius: 999px;
		background: rgba(244, 239, 231, 0.78);
		border: 1px solid var(--line);
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.9rem;
		height: 3rem;
		padding: 0;
		border-radius: 999px;
		border: 1px solid transparent;
		background: transparent;
		color: var(--ink-soft);
		font: inherit;
		cursor: pointer;
	}

	.theme-toggle:hover {
		background: rgba(255, 255, 255, 0.82);
		border-color: var(--line);
	}

	.theme-toggle-track {
		position: relative;
		display: inline-block;
		width: 3.15rem;
		height: 1.8rem;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(239, 180, 126, 0.2), rgba(93, 154, 121, 0.16));
		border: 1px solid rgba(100, 132, 114, 0.14);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
		overflow: hidden;
	}

	.theme-toggle-sun,
	.theme-toggle-moon {
		position: absolute;
		top: 50%;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 0.8rem;
		height: 0.8rem;
		font-size: 0.74rem;
		line-height: 1;
		transition:
			opacity var(--transition),
			transform var(--transition),
			color var(--transition);
		transform: translateY(-50%);
	}

	.theme-toggle-sun {
		left: 0.38rem;
		color: #b56e2e;
	}

	.theme-toggle-moon {
		right: 0.38rem;
		color: #47715d;
	}

	.theme-toggle-thumb {
		position: absolute;
		top: 0.13rem;
		left: 0.14rem;
		width: 1.3rem;
		height: 1.3rem;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 248, 246, 0.92));
		box-shadow:
			0 8px 18px rgba(43, 38, 30, 0.14),
			inset 0 1px 0 rgba(255, 255, 255, 0.8);
		transition:
			transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
			background var(--transition),
			box-shadow var(--transition);
	}

	html[data-theme="dark"] .theme-toggle-track {
		background: linear-gradient(90deg, rgba(21, 34, 28, 0.96), rgba(30, 45, 37, 0.94));
		border-color: rgba(141, 172, 151, 0.18);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	html[data-theme="dark"] .theme-toggle-thumb {
		transform: translateX(1.55rem);
		background: linear-gradient(180deg, rgba(132, 153, 139, 0.96), rgba(86, 107, 94, 0.96));
		box-shadow:
			0 8px 18px rgba(0, 0, 0, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.12);
	}

	html[data-theme="dark"] .theme-toggle-sun {
		opacity: 0.45;
		transform: translateY(-50%) scale(0.92);
	}

	html[data-theme="dark"] .theme-toggle-moon {
		opacity: 1;
		transform: translateY(-50%);
		color: #dceae0;
	}

	html:not([data-theme="dark"]) .theme-toggle-sun {
		opacity: 1;
		transform: translateY(-50%);
	}

	html:not([data-theme="dark"]) .theme-toggle-moon {
		opacity: 0.45;
		transform: translateY(-50%) scale(0.92);
	}

	@media (max-width: 720px) {
		.header-shell {
			border-radius: var(--radius-xl);
			padding: 0.75rem;
			flex-direction: column;
			align-items: stretch;
		}

		.identity {
			justify-content: center;
		}

		.header-extras {
			justify-content: center;
		}

		.nav-links {
			justify-content: center;
		}
	}
</style>

<script>
	const root = document.documentElement;
	const toggle = document.querySelector('[data-theme-toggle]');
	const region = document.querySelector('[data-toast-region]');

	const showToast = (message) => {
		if (!region) return;
		const toast = document.createElement('div');
		toast.className = 'toast';
		toast.textContent = message;
		region.appendChild(toast);
		window.setTimeout(() => toast.remove(), 1800);
	};

	window.showToast = showToast;

	const applyTheme = (theme) => {
		root.dataset.theme = theme;
		localStorage.setItem('sonder-theme', theme);
		toggle?.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
		window.dispatchEvent(new CustomEvent('sonder:theme-change', { detail: { theme } }));
	};

	if (toggle) {
		toggle.setAttribute('aria-pressed', root.dataset.theme === 'dark' ? 'true' : 'false');
	}

	toggle?.addEventListener('click', () => {
		const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
		applyTheme(next);
		showToast(next === 'dark' ? '已切换到夜间模式' : '已切换到日间模式');
	});
</script>
