---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ProfileImage from '../assets/profile.jpg';

const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="shell header-shell">
		<a href={baseURL} class="identity">
			<Image src={ProfileImage} alt="sonder avatar" width={56} height={56} />
			<div class="identity-copy">
				<span class="eyebrow">Sonder's Notes</span>
				<strong>{SITE_TITLE}</strong>
			</div>
		</a>
		<nav class="nav-links" aria-label="Primary">
			<HeaderLink href={baseURL}>首页</HeaderLink>
			<HeaderLink href={`${baseURL}blog`}>文章</HeaderLink>
			<HeaderLink href={`${baseURL}about`}>关于</HeaderLink>
			<button type="button" class="theme-toggle" aria-label="切换夜间模式" data-theme-toggle>
				<span class="theme-light">昼</span>
				<span class="theme-dark">夜</span>
			</button>
		</nav>
	</div>
</header>

<div class="toast-region" aria-live="polite" aria-atomic="true" data-toast-region></div>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		background: linear-gradient(180deg, rgba(251, 248, 242, 0.96), rgba(251, 248, 242, 0.72), transparent);
		backdrop-filter: blur(14px);
	}

	.header-shell {
		min-height: 74px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.65rem 0.85rem;
		border-radius: 999px;
		background: rgba(255, 252, 247, 0.84);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-sm);
	}

	.identity {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
		padding: 0.3rem 0.45rem;
		border-radius: 999px;
	}

	.identity :global(img) {
		width: 3.3rem;
		height: 3.3rem;
		border-radius: 999px;
		object-fit: cover;
		box-shadow: 0 8px 22px rgba(43, 38, 30, 0.12);
	}

	.identity-copy {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.identity-copy strong {
		font-family: var(--font-display);
		font-size: 1.25rem;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	.identity-copy .eyebrow {
		font-size: 0.7rem;
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		padding: 0.24rem;
		border-radius: 999px;
		background: rgba(244, 239, 231, 0.78);
		border: 1px solid var(--line);
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.68rem 0.82rem;
		border-radius: 999px;
		border: 1px solid transparent;
		background: transparent;
		color: var(--ink-soft);
		font: inherit;
		font-size: 0.82rem;
		font-weight: 700;
		cursor: pointer;
	}

	.theme-toggle:hover {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.82);
		border-color: var(--line);
	}

	@media (max-width: 720px) {
		.header-shell {
			border-radius: var(--radius-xl);
			padding: 0.75rem;
			flex-direction: column;
			align-items: stretch;
		}

		.identity {
			justify-content: center;
		}

		.nav-links {
			justify-content: center;
		}
	}
</style>

<script>
	const root = document.documentElement;
	const toggle = document.querySelector('[data-theme-toggle]');
	const region = document.querySelector('[data-toast-region]');

	const showToast = (message) => {
		if (!region) return;
		const toast = document.createElement('div');
		toast.className = 'toast';
		toast.textContent = message;
		region.appendChild(toast);
		window.setTimeout(() => toast.remove(), 1800);
	};

	window.showToast = showToast;

	const applyTheme = (theme) => {
		root.dataset.theme = theme;
		localStorage.setItem('sonder-theme', theme);
	};

	toggle?.addEventListener('click', () => {
		const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
		applyTheme(next);
		showToast(next === 'dark' ? '已切换到夜间模式' : '已切换到日间模式');
	});
</script>
