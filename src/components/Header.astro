---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ProfileImage from '../assets/profile.jpg';

const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="shell header-shell">
		<a href={baseURL} class="identity">
			<Image src={ProfileImage} alt="sonder avatar" width={64} height={64} />
			<div class="identity-copy">
				<strong>{SITE_TITLE}</strong>
				<span>无限进步</span>
			</div>
		</a>
		<nav class="nav-links" aria-label="Primary">
			<HeaderLink href={baseURL}>首页</HeaderLink>
			<HeaderLink href={`${baseURL}blog`}>文章</HeaderLink>
			<HeaderLink href={`${baseURL}about`}>关于</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		background: linear-gradient(180deg, rgba(248, 250, 247, 0.95), rgba(248, 250, 247, 0.72), transparent);
		backdrop-filter: blur(14px);
	}

	.header-shell {
		min-height: 80px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		background: rgba(250, 252, 249, 0.92);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-sm);
	}

	.identity {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
		min-width: 0;
		padding: 0.35rem 0.5rem;
		border-radius: 999px;
	}

	.identity :global(img) {
		width: 3.9rem;
		height: 3.9rem;
		border-radius: 999px;
		object-fit: cover;
		box-shadow: 0 8px 20px rgba(58, 76, 64, 0.1);
	}

	.identity-copy {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.identity-copy strong {
		font-size: 1.15rem;
		line-height: 1.1;
	}

	.identity-copy span {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		color: var(--ink-faint);
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.34rem;
		border-radius: 999px;
		background: rgba(239, 245, 240, 0.96);
		border: 1px solid var(--line);
	}

	@media (max-width: 720px) {
		.header-shell {
			border-radius: var(--radius-lg);
			padding: 0.75rem;
			flex-direction: column;
			align-items: stretch;
		}

		.identity {
			justify-content: center;
		}

		.nav-links {
			justify-content: center;
		}
	}
</style>
