---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ProfileImage from '../assets/profile.jpg';

const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="shell header-shell">
		<a href={baseURL} class="identity">
			<Image src={ProfileImage} alt="sonder avatar" width={58} height={58} />
			<div class="identity-copy">
				<strong>{SITE_TITLE}</strong>
				<span>个人学习博客</span>
			</div>
		</a>
		<nav class="nav-links" aria-label="Primary">
			<HeaderLink href={baseURL}>首页</HeaderLink>
			<HeaderLink href={`${baseURL}blog`}>文章</HeaderLink>
			<HeaderLink href={`${baseURL}about`}>关于</HeaderLink>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		background: linear-gradient(180deg, rgba(247, 251, 248, 0.94), rgba(247, 251, 248, 0.68), transparent);
		backdrop-filter: blur(14px);
	}

	.header-shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1rem;
		border-radius: 999px;
		background: rgba(248, 252, 249, 0.9);
		border: 1px solid rgba(103, 129, 114, 0.18);
		box-shadow: 0 18px 38px rgba(84, 110, 92, 0.08);
	}

	.identity {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
		min-width: 0;
		padding: 0.35rem 0.45rem;
		border-radius: 999px;
	}

	.identity :global(img) {
		width: 3.6rem;
		height: 3.6rem;
		border-radius: 999px;
		object-fit: cover;
		box-shadow: 0 10px 24px rgba(84, 110, 92, 0.1);
	}

	.identity-copy {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.identity-copy strong {
		font-size: 1.1rem;
		line-height: 1.1;
	}

	.identity-copy span {
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-faint);
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.38rem;
		border-radius: 999px;
		background: rgba(236, 243, 238, 0.96);
		border: 1px solid rgba(103, 129, 114, 0.14);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7), 0 10px 20px rgba(84, 110, 92, 0.05);
	}

	@media (max-width: 720px) {
		.header-shell {
			border-radius: 28px;
			padding: 0.85rem;
			flex-direction: column;
			align-items: stretch;
		}

		.identity {
			justify-content: center;
		}

		.nav-links {
			justify-content: center;
		}
	}
</style>
