---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/');
const normalizedHref = typeof href === 'string' ? href.replace(import.meta.env.BASE_URL, '/') : href;
const subpath = pathname.match(/[^\\/]+/g);
const isActive = normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>

<style>
	a {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.76rem 1.16rem;
		border-radius: 999px;
		color: var(--ink-soft);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		background: transparent;
		border: 1px solid transparent;
	}

	a:hover {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.88);
		border-color: var(--line);
		box-shadow: 0 8px 18px rgba(58, 76, 64, 0.07);
	}

	a.active {
		color: var(--ink);
		font-weight: 800;
		background: linear-gradient(180deg, #ffffff, #f6faf6);
		border-color: rgba(120, 150, 127, 0.36);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.96), 0 10px 22px rgba(58, 76, 64, 0.08);
	}
</style>
