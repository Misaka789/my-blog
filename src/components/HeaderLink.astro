---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/');
const normalizedHref = typeof href === 'string' ? href.replace(import.meta.env.BASE_URL, '/') : href;
const subpath = pathname.match(/[^\\/]+/g);
const isActive = normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>

<style>
	a {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1.18rem;
		border-radius: 999px;
		color: var(--ink-soft);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		background: transparent;
		border: 1px solid transparent;
	}

	a:hover {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.82);
		border-color: rgba(103, 129, 114, 0.14);
		box-shadow: 0 10px 22px rgba(84, 110, 92, 0.08);
	}

	a.active {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.96);
		border-color: rgba(103, 129, 114, 0.16);
		box-shadow: 0 12px 26px rgba(84, 110, 92, 0.1);
	}
</style>
