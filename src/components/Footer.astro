---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Smoggy Saturn Lab</p>
	<p class="note">Built with <a href="https://astro.build/">Astro</a>. Source on <a href="https://github.com/withastro/astro">GitHub</a>.</p>
</footer>
<style>
	footer {
		max-width: 680px;
		margin: 0 auto;
		padding: 2em 1.5em 3em;
		border-top: 1px solid var(--border);
		text-align: center;
	}
	footer p {
		color: var(--text-muted);
		font-size: 0.85em;
		margin: 0.3em 0;
	}
	footer .note {
		font-size: 0.8em;
	}
	footer a {
		color: var(--text-muted);
		text-decoration-color: rgba(255, 255, 255, 0.1);
	}
	footer a:hover {
		color: var(--text-secondary);
	}
</style>