---
import BackToTop from './BackToTop.astro';
const today = new Date();
const baseURL = import.meta.env.BASE_URL;
---

<BackToTop />
<footer class="site-footer">
	<div class="shell footer-shell">
		<h2>sonder</h2>
		<p>记录学习过程、实践复盘，以及那些值得回看的成长片段。</p>
		<div class="footer-links">
			<a href={baseURL}>首页</a>
			<a href={`${baseURL}blog`}>文章</a>
			<a href={`${baseURL}about`}>关于</a>
			<a href="mailto:3192422357@qq.com">邮箱</a>
			<a href={`${baseURL}rss.xml`}>RSS</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} sonder</p>
	</div>
</footer>

<style>
	.site-footer {
		padding-bottom: var(--space-6);
	}

	.footer-shell {
		display: grid;
		gap: var(--space-2);
		justify-items: center;
		text-align: center;
		padding: var(--space-6) 0 0;
		margin-top: var(--space-7);
		border-top: 1px solid var(--line);
	}

	.footer-shell h2 {
		font-size: 1.7rem;
		font-family: var(--font-display);
		letter-spacing: -0.04em;
	}

	.footer-shell > p {
		max-width: 32rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-2) var(--space-4);
		margin-top: var(--space-2);
	}

	.footer-links a {
		color: var(--ink-soft);
		font-weight: 600;
		border-bottom: 1px solid transparent;
	}

	.footer-links a:hover {
		color: var(--ink);
		border-color: var(--line-strong);
	}

	.copyright {
		color: var(--ink-faint);
		font-size: 0.9rem;
		margin-top: var(--space-2);
	}
</style>