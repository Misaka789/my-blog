---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CategorizedPost } from '../data/categories';
import { toCategoryId } from '../data/categories';

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	category: string;
	categorySummary?: string;
	headings?: TocHeading[];
	readingTime?: number;
	previousPost?: CategorizedPost;
	nextPost?: CategorizedPost;
};

const {
	title,
	description,
	category,
	pubDate,
	updatedDate,
	heroImage,
	categorySummary = '',
	headings = [],
	readingTime = 1,
	previousPost,
	nextPost,
} = Astro.props;

const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(calc(100% - 2rem), 1180px);
			}

			.progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 100%;
				background: transparent;
				z-index: 90;
			}

			.progress::after {
				content: '';
				display: block;
				height: 100%;
				width: var(--progress, 0%);
				background: linear-gradient(90deg, var(--accent-warm), var(--accent));
				transition: width 100ms linear;
			}

			.progress-badge {
				position: fixed;
				right: 1rem;
				bottom: 1rem;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 3.4rem;
				padding: 0.7rem 0.8rem;
				border-radius: 999px;
				background: rgba(22, 31, 26, 0.9);
				color: white;
				font-size: 0.82rem;
				font-weight: 700;
				z-index: 90;
			}

			.article-shell {
				display: grid;
				gap: var(--space-4);
				padding-top: var(--space-4);
			}

			.article-hero,
			.hero-media,
			.article-body,
			.article-toc,
			.article-nav {
				padding: var(--space-5);
			}

			.article-hero {
				display: grid;
				gap: 0.9rem;
			}

			.article-hero h1 {
				max-width: 18ch;
				font-size: clamp(2rem, 3.4vw, 3rem);
				line-height: 1.04;
				letter-spacing: -0.045em;
			}

			.article-hero p {
				max-width: 38rem;
				font-size: 0.98rem;
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.meta-pill,
			.meta-button,
			.category-pill,
			.toc-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.66rem 0.84rem;
				border-radius: 999px;
				background: rgba(255, 252, 247, 0.8);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
				font-size: 0.86rem;
			}

			.meta-button {
				cursor: pointer;
			}

			.category-pill:hover,
			.meta-button:hover,
			.back-link:hover,
			.nav-card:hover,
			.related-card:hover,
			.toc-link:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.hero-media :global(img) {
				width: 100%;
				object-fit: cover;
				aspect-ratio: 1 / 0.6;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.prose :global(img) {
				cursor: zoom-in;
				transition: transform var(--transition), box-shadow var(--transition);
			}

			.prose :global(img:hover) {
				transform: translateY(-1px);
				box-shadow: var(--shadow-sm);
			}

			.article-content {
				display: grid;
				grid-template-columns: minmax(0, 1fr);
				gap: var(--space-3);
				align-items: start;
			}

			.article-content.has-toc {
				grid-template-columns: 220px minmax(0, 1fr);
				gap: var(--space-4);
			}

			.article-body {
				background: rgba(255, 253, 249, 0.96);
				border-radius: 16px;
				border: 1px solid rgba(116, 108, 94, 0.12);
				box-shadow: 0 10px 24px rgba(43, 38, 30, 0.04);
			}

			.prose {
				display: grid;
				gap: 1.05rem;
				font-size: 1rem;
				line-height: 1.9;
			}

			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				scroll-margin-top: 6rem;
				font-family: var(--font-display);
				letter-spacing: -0.035em;
			}

			.prose :global(h2) {
				margin-top: 2.4rem;
				font-size: clamp(1.6rem, 2.6vw, 2.15rem);
				line-height: 1.12;
			}

			.prose :global(h3) {
				margin-top: 1.5rem;
				font-size: clamp(1.2rem, 2vw, 1.45rem);
				line-height: 1.18;
			}

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol),
			.prose :global(blockquote) {
				max-width: 42rem;
			}

			.prose :global(a) {
				color: var(--accent-strong);
				text-decoration: underline;
				text-decoration-color: rgba(96, 120, 103, 0.32);
				text-underline-offset: 0.18em;
			}

			.prose :global(p + p) {
				margin-top: 0.15rem;
			}

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.15rem;
			}

			.prose :global(li) {
				padding-left: 0.05rem;
			}

			.prose :global(pre) {
				max-width: 100%;
			}

			.article-toc {
				position: sticky;
				top: 6.1rem;
				display: grid;
				gap: 0.45rem;
				align-self: start;
				padding: 0.35rem 0 0 0;
				background: transparent;
				border: 0;
				box-shadow: none;
				backdrop-filter: none;
			}

			.toc-list {
				display: grid;
				gap: 0.35rem;
				padding-left: 0.85rem;
				border-left: 1px solid var(--line);
			}

			.toc-link {
				justify-content: start;
				width: 100%;
				text-align: left;
				padding: 0.5rem 0.2rem;
				border-radius: 6px;
				border: 0;
				background: transparent;
				box-shadow: none;
				font-weight: 600;
				font-size: 0.88rem;
			}

			.toc-link.active {
				color: var(--accent-strong);
				background: rgba(93, 154, 121, 0.06);
			}

			.toc-link.depth-3 {
				padding-left: 1.15rem;
				font-size: 0.82rem;
				color: var(--ink-faint);
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1.2rem;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				background: rgba(255, 252, 247, 0.82);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.top-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 0.9rem;
				padding: 0.76rem 0.95rem;
				border-radius: 999px;
				background: transparent;
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.article-nav {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.nav-card {
				display: grid;
				gap: 0.65rem;
				padding: var(--space-4);
				background: rgba(255, 252, 247, 0.78);
				border: 1px solid var(--line);
				border-radius: 12px;
				box-shadow: var(--shadow-sm);
			}

			.image-lightbox {
				position: fixed;
				inset: 0;
				display: none;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				background: rgba(0, 0, 0, 0.72);
				z-index: 120;
			}

			.image-lightbox.open {
				display: flex;
			}

			.image-lightbox img {
				max-width: min(1100px, 100%);
				max-height: 86vh;
				border-radius: 12px;
			}

			.nav-card span {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}

			.nav-card h3 {
				font-size: 1.18rem;
				line-height: 1.18;
			}

			@media (max-width: 960px) {
				.article-content.has-toc,
				.article-nav {
					grid-template-columns: 1fr;
				}

				.article-toc {
					position: static;
					order: -1;
					padding-top: 0;
				}
			}

			@media (max-width: 720px) {
				main {
					width: min(calc(100% - 1rem), 1180px);
				}

				.article-hero,
				.hero-media,
				.article-body,
				.article-toc,
				.article-nav {
					padding: var(--space-4);
				}

				.article-hero h1 {
					font-size: clamp(1.75rem, 8vw, 2.35rem);
				}

				.meta-row {
					gap: 0.5rem;
				}

				.meta-pill,
				.meta-button,
				.category-pill {
					font-size: 0.8rem;
					padding: 0.58rem 0.72rem;
				}

				.prose {
					font-size: 0.98rem;
					line-height: 1.82;
				}

				.prose :global(h2) {
					margin-top: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="progress" aria-hidden="true"></div>
		<div class="progress-badge" data-progress-badge>0%</div>
		<Header />
		<main>
			<article class="article-shell">
				<header class="article-hero soft-panel">
					<span class="section-tag">文章</span>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="meta-row">
						<a class="category-pill" href={`${import.meta.env.BASE_URL}blog#${toCategoryId(category)}`}>{category}</a>
						<span class="meta-pill"><FormattedDate date={pubDate} /></span>
						<span class="meta-pill">约 {readingTime} 分钟</span>
						<button class="meta-button" type="button" data-copy-link>复制链接</button>
						{updatedDate && <span class="meta-pill">更新于 <FormattedDate date={updatedDate} /></span>}
					</div>
					{categorySummary && <p>{categorySummary}</p>}
				</header>

				{heroImage && (
					<div class="hero-media soft-panel">
						<Image width={1400} height={800} src={heroImage} alt={title} />
					</div>
				)}

				<div class:list={['article-content', { 'has-toc': tocItems.length > 0 }]}>
					{tocItems.length > 0 && (
						<aside class="article-toc soft-panel">
							<div class="toc-list">
								{tocItems.map((heading) => (
									<a class={`toc-link depth-${heading.depth}`} href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
								))}
							</div>
						</aside>
					)}

					<div class="article-body soft-panel">
						<div class="prose">
							<slot />
						</div>
						<a href={`${import.meta.env.BASE_URL}blog`} class="back-link">返回文章列表</a>
						<a href="#top" class="top-link" data-top-link>回到顶部</a>
					</div>
				</div>

				{(previousPost || nextPost) && (
					<section class="article-nav soft-panel">
						{previousPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${previousPost.id}/`}>
								<span>上一篇</span>
								<h3>{previousPost.data.title}</h3>
								<p>{previousPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
						{nextPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${nextPost.id}/`}>
								<span>下一篇</span>
								<h3>{nextPost.data.title}</h3>
								<p>{nextPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
					</section>
				)}
			</article>
		</main>
		<Footer />
		<div class="image-lightbox" data-lightbox>
			<img alt="" data-lightbox-image />
		</div>
		<script>
			const copyButton = document.querySelector('[data-copy-link]');
			if (copyButton) {
				copyButton.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(window.location.href);
						window.showToast?.('链接已复制');
					} catch {
						window.showToast?.('复制失败');
					}
				});
			}

			const progress = document.querySelector('.progress');
			const progressBadge = document.querySelector('[data-progress-badge]');
			const updateProgress = () => {
				if (!progress) return;
				const scrollTop = window.scrollY;
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const ratio = max <= 0 ? 0 : Math.min(1, Math.max(0, scrollTop / max));
				const percent = `${Math.round(ratio * 100)}%`;
				progress.style.setProperty('--progress', `${(ratio * 100).toFixed(2)}%`);
				if (progressBadge) progressBadge.textContent = percent;
			};
			window.addEventListener('scroll', updateProgress, { passive: true });
			updateProgress();

			const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
			const headingTargets = tocLinks
				.map((link) => {
					const slug = link.getAttribute('data-toc-link');
					const target = slug ? document.getElementById(slug) : null;
					return target ? { link, target } : null;
				})
				.filter(Boolean);

			if (headingTargets.length > 0) {
				const activateLink = (id) => {
					headingTargets.forEach(({ link, target }) => {
						link.classList.toggle('active', target.id === id);
					});
				};

				const observer = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
						if (visible[0]?.target?.id) {
							activateLink(visible[0].target.id);
						}
					},
					{
						rootMargin: '-20% 0px -65% 0px',
						threshold: [0, 1],
					},
				);

				headingTargets.forEach(({ target }) => observer.observe(target));
				activateLink(headingTargets[0].target.id);
			}

			const proseImages = Array.from(document.querySelectorAll('.prose img'));
			const lightbox = document.querySelector('[data-lightbox]');
			const lightboxImage = document.querySelector('[data-lightbox-image]');
			const topLink = document.querySelector('[data-top-link]');

			topLink?.addEventListener('click', (event) => {
				event.preventDefault();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			proseImages.forEach((image) => {
				image.addEventListener('click', () => {
					if (!lightbox || !lightboxImage) return;
					lightboxImage.src = image.currentSrc || image.src;
					lightboxImage.alt = image.alt || '';
					lightbox.classList.add('open');
				});
			});

			lightbox?.addEventListener('click', () => {
				lightbox.classList.remove('open');
			});

			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					lightbox?.classList.remove('open');
				}
			});
		</script>
	</body>
</html>
