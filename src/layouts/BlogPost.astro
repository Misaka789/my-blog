---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CategorizedPost } from '../data/categories';
import { toCategoryId } from '../data/categories';

type Props = CollectionEntry<'blog'>['data'] & {
	category: string;
	categorySummary?: string;
	relatedPosts?: CategorizedPost[];
};

const {
	title,
	description,
	category,
	pubDate,
	updatedDate,
	heroImage,
	categorySummary = '',
	relatedPosts = [],
} = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(calc(100% - 2rem), 1040px);
			}

			.article-shell {
				display: grid;
				gap: 1.25rem;
				padding-top: 1rem;
			}

			.article-hero {
				padding: 1.8rem;
				display: grid;
				gap: 1rem;
			}

			.article-hero p {
				max-width: 44rem;
				font-size: 1.06rem;
			}

			.section-head {
				display: grid;
				gap: 0.8rem;
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}

			.meta-pill,
			.category-pill,
			.post-category {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.78rem 1rem;
				border-radius: 999px;
				background: rgba(248, 253, 249, 0.88);
				border: 1px solid rgba(103, 129, 114, 0.15);
				color: var(--ink-soft);
				font-weight: 700;
				box-shadow: var(--shadow-sm);
			}

			.category-pill:hover,
			.back-link:hover,
			.related-card:hover {
				transform: translateY(-2px);
				background: white;
			}

			.hero-media {
				padding: 1rem;
			}

			.hero-media :global(img) {
				width: 100%;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.article-body {
				padding: clamp(1.4rem, 3vw, 2.8rem);
				max-width: var(--content-width);
				margin: 0 auto;
			}

			.prose {
				display: grid;
				gap: 1rem;
			}

			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				scroll-margin-top: 6rem;
			}

			.prose :global(h2) {
				margin-top: 2rem;
			}

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol) {
				max-width: 42rem;
			}

			.prose :global(a) {
				color: var(--accent-strong);
				text-decoration: underline;
				text-decoration-color: rgba(95, 141, 116, 0.3);
				text-underline-offset: 0.18em;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1.25rem;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				background: rgba(250, 255, 251, 0.84);
				border: 1px solid rgba(103, 129, 114, 0.14);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.related-section {
				padding: 1.6rem;
				display: grid;
				gap: 1rem;
			}

			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}

			.related-card {
				display: grid;
				gap: 0.7rem;
				padding: 1.25rem;
				background: rgba(248, 253, 249, 0.88);
				border: 1px solid rgba(103, 129, 114, 0.15);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
			}

			.related-card h3 {
				font-size: 1.2rem;
				line-height: 1.18;
			}

			.post-meta {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.86rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				color: var(--ink-faint);
			}

			.post-meta::before {
				content: "";
				width: 0.45rem;
				height: 0.45rem;
				border-radius: 999px;
				background: var(--accent-warm);
			}

			@media (max-width: 720px) {
				main {
					width: min(calc(100% - 1rem), 1040px);
				}

				.article-hero,
				.hero-media,
				.related-section {
					padding: 1.2rem;
				}

				.related-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article-shell">
				<header class="article-hero soft-panel">
					<span class="section-tag">文章</span>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="meta-row">
						<a class="category-pill" href={`${import.meta.env.BASE_URL}blog#${toCategoryId(category)}`}>{category}</a>
						<span class="meta-pill"><FormattedDate date={pubDate} /></span>
						{updatedDate && <span class="meta-pill">更新于 <FormattedDate date={updatedDate} /></span>}
					</div>
					{categorySummary && <p>{categorySummary}</p>}
				</header>

				{heroImage && (
					<div class="hero-media soft-panel">
						<Image width={1400} height={800} src={heroImage} alt="" />
					</div>
				)}

				<div class="article-body soft-panel">
					<div class="prose">
						<slot />
					</div>
					<a href={`${import.meta.env.BASE_URL}blog`} class="back-link">返回文章归档</a>
				</div>

				{relatedPosts.length > 0 && (
					<section class="related-section soft-panel">
						<div class="section-head">
							<span class="section-tag">继续阅读</span>
							<h2>接着看看这些文章</h2>
							<p>如果这篇对你有帮助，可以顺着下面这些内容继续读下去。</p>
						</div>
						<div class="related-grid">
							{relatedPosts.map((post) => (
								<a class="related-card" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
									<div class="post-category">{post.categoryName}</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<div class="post-meta"><FormattedDate date={post.data.pubDate} /></div>
								</a>
							))}
						</div>
					</section>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
