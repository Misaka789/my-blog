---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CategorizedPost } from '../data/categories';
import { toCategoryId } from '../data/categories';

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	category: string;
	categorySummary?: string;
	headings?: TocHeading[];
	readingTime?: number;
	previousPost?: CategorizedPost;
	nextPost?: CategorizedPost;
};

const {
	title,
	description,
	category,
	pubDate,
	updatedDate,
	heroImage,
	categorySummary = '',
	headings = [],
	readingTime = 1,
	previousPost,
	nextPost,
} = Astro.props;

const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(calc(100% - 2rem), 1180px);
			}

			.progress {
				position: relative;
				display: grid;
				gap: 0.55rem;
				width: min(100%, 320px);
				padding: 0.72rem 0.82rem;
				border-radius: 18px;
				background: var(--header-shell-bg);
				border: 1px solid var(--line);
				box-shadow: 0 10px 24px rgba(43, 38, 30, 0.08);
				backdrop-filter: blur(18px);
				transition:
					box-shadow 260ms var(--transition),
					opacity 220ms var(--transition),
					transform 220ms var(--transition),
					max-height 220ms var(--transition),
					padding 220ms var(--transition);
			}

			.progress.engaged {
				box-shadow: 0 14px 30px rgba(43, 38, 30, 0.12);
			}

			.progress-topline {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}

			.progress-label {
				font-size: 0.68rem;
				font-weight: 800;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--ink-faint);
			}

			.progress-badge {
				font-size: 0.92rem;
				font-weight: 800;
				letter-spacing: -0.04em;
				color: var(--ink);
			}

			.progress-toggle {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.34rem 0.56rem;
				border-radius: 999px;
				border: 0;
				background: rgba(93, 154, 121, 0.08);
				color: var(--ink-faint);
				font: inherit;
				font-size: 0.72rem;
				font-weight: 700;
				cursor: pointer;
				transition:
					transform var(--transition),
					background-color var(--transition),
					color var(--transition);
			}

			.progress-toggle:hover {
				transform: translateY(-1px);
				background: rgba(93, 154, 121, 0.14);
				color: var(--ink);
			}

			.progress-track {
				position: relative;
				height: 0.62rem;
				border-radius: 999px;
				background:
					linear-gradient(90deg, rgba(93, 154, 121, 0.08), rgba(226, 168, 111, 0.16)),
					rgba(255, 255, 255, 0.65);
				border: 1px solid rgba(116, 108, 94, 0.08);
				overflow: hidden;
			}

			.progress-fill {
				height: 100%;
				width: var(--progress, 0%);
				border-radius: inherit;
				background: linear-gradient(90deg, var(--accent), var(--accent-warm));
				box-shadow: 0 0 18px rgba(93, 154, 121, 0.3);
				transition: width 140ms linear;
			}

			.progress-meta {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 0.7rem;
				align-items: center;
			}

			.progress-section {
				min-width: 0;
			}

			.progress-section-title {
				display: block;
				font-size: 0.84rem;
				font-weight: 700;
				line-height: 1.3;
				color: var(--ink);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.progress-section-subtitle {
				display: block;
				margin-top: 0.1rem;
				font-size: 0.72rem;
				color: var(--ink-faint);
			}

			.progress-chip {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.42rem 0.62rem;
				border-radius: 999px;
				background: rgba(29, 41, 34, 0.88);
				color: white;
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.03em;
			}

			.progress.collapsed {
				gap: 0;
				max-height: 3.2rem;
				overflow: hidden;
			}

			.progress.collapsed .progress-track,
			.progress.collapsed .progress-meta {
				opacity: 0;
				transform: translateY(-6px);
				pointer-events: none;
			}

			.article-shell {
				display: grid;
				gap: var(--space-4);
				padding-top: var(--space-4);
			}

			.article-hero,
			.hero-media,
			.article-body,
			.article-toc,
			.article-nav {
				padding: var(--space-5);
			}

			.article-hero {
				display: grid;
				gap: 0.95rem;
			}

			.article-hero h1 {
				max-width: 14ch;
				font-size: clamp(2rem, 3.4vw, 3rem);
				line-height: 1.04;
				letter-spacing: -0.045em;
			}

			.article-hero p {
				max-width: 44rem;
				font-size: 0.98rem;
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.meta-pill,
			.meta-button,
			.category-pill,
			.toc-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.66rem 0.84rem;
				border-radius: 999px;
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
				font-size: 0.86rem;
			}

			.meta-button {
				cursor: pointer;
			}

			.category-pill:hover,
			.meta-button:hover,
			.back-link:hover,
			.nav-card:hover,
			.related-card:hover,
			.toc-link:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.hero-media :global(img) {
				width: 100%;
				object-fit: cover;
				aspect-ratio: 1 / 0.6;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.prose :global(img) {
				cursor: zoom-in;
				transition: transform var(--transition), box-shadow var(--transition);
			}

			.prose :global(img:hover) {
				transform: translateY(-1px);
				box-shadow: var(--shadow-sm);
			}

			.article-content {
				display: grid;
				grid-template-columns: minmax(0, 1fr);
				gap: var(--space-3);
				align-items: start;
			}

			.article-content.has-toc {
				grid-template-columns: 220px minmax(0, 1fr);
				gap: var(--space-4);
			}

			.article-body {
				display: grid;
				justify-content: center;
				background: var(--article-body-bg);
				border-radius: 16px;
				border: 1px solid var(--article-body-border);
				box-shadow: 0 10px 24px rgba(43, 38, 30, 0.04);
			}

			.prose {
				display: grid;
				width: min(100%, 42rem);
				gap: 1.15rem;
				font-size: 1.04rem;
				line-height: 1.95;
				color: var(--ink-soft);
			}

			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				scroll-margin-top: 6rem;
				font-family: var(--font-display);
				letter-spacing: -0.035em;
				color: var(--ink);
			}

			.prose :global(h2) {
				position: relative;
				margin-top: 2.9rem;
				padding-top: 1rem;
				font-size: clamp(1.6rem, 2.6vw, 2.15rem);
				line-height: 1.12;
			}

			.prose :global(h2)::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				width: 4rem;
				height: 2px;
				border-radius: 999px;
				background: linear-gradient(90deg, var(--accent-warm), var(--accent));
			}

			.prose :global(h3) {
				margin-top: 2rem;
				font-size: clamp(1.2rem, 2vw, 1.45rem);
				line-height: 1.18;
			}

			.prose :global(h4) {
				margin-top: 1.4rem;
				font-size: 1.05rem;
				line-height: 1.3;
			}

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol),
			.prose :global(blockquote),
			.prose :global(table) {
				max-width: 42rem;
			}

			.prose :global(p) {
				text-wrap: pretty;
			}

			.prose :global(a) {
				color: var(--accent-strong);
				text-decoration: underline;
				text-decoration-color: rgba(96, 120, 103, 0.32);
				text-underline-offset: 0.18em;
				text-decoration-thickness: 0.08em;
			}

			.prose :global(p + p) {
				margin-top: 0.35rem;
			}

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.25rem;
			}

			.prose :global(li) {
				padding-left: 0.14rem;
			}

			.prose :global(ul li::marker) {
				color: var(--accent);
			}

			.prose :global(ol li::marker) {
				color: var(--accent-strong);
				font-weight: 700;
			}

			.prose :global(pre:not(.mermaid)) {
				position: relative;
				max-width: 100%;
				margin: 0;
				padding: 1rem 1.25rem 1.1rem;
				border-radius: 16px;
				background:
					linear-gradient(180deg, rgba(18, 29, 23, 0.98), rgba(18, 29, 23, 0.94)),
					linear-gradient(135deg, rgba(120, 195, 151, 0.14), rgba(239, 180, 126, 0.12));
				border: 1px solid rgba(120, 195, 151, 0.14);
				box-shadow:
					inset 0 1px 0 rgba(255, 255, 255, 0.06),
					0 14px 32px rgba(24, 31, 27, 0.18);
			}

			.prose :global(.code-block) {
				display: grid;
				gap: 0.65rem;
				max-width: 100%;
				margin: 1.6rem 0;
			}

			.prose :global(.code-toolbar) {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				flex-wrap: wrap;
				padding: 0 0.15rem;
			}

			.prose :global(.code-language) {
				display: inline-flex;
				align-items: center;
				padding: 0.3rem 0.56rem;
				border-radius: 999px;
				background: rgba(239, 247, 242, 0.1);
				border: 1px solid rgba(239, 247, 242, 0.08);
				color: rgba(239, 247, 242, 0.82);
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.prose :global(.code-copy) {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.34rem 0.62rem;
				border-radius: 999px;
				border: 1px solid rgba(239, 247, 242, 0.1);
				background: rgba(239, 247, 242, 0.08);
				color: rgba(239, 247, 242, 0.9);
				font-size: 0.72rem;
				font-weight: 700;
				cursor: pointer;
				transition:
					transform var(--transition),
					background-color var(--transition),
					border-color var(--transition),
					color var(--transition);
			}

			.prose :global(.code-copy:hover) {
				transform: translateY(-1px);
				background: rgba(239, 247, 242, 0.14);
				border-color: rgba(239, 247, 242, 0.16);
			}

			.prose :global(.code-expand) {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.34rem 0.62rem;
				border-radius: 999px;
				border: 1px solid rgba(239, 247, 242, 0.1);
				background: rgba(239, 247, 242, 0.08);
				color: rgba(239, 247, 242, 0.9);
				font-size: 0.72rem;
				font-weight: 700;
				cursor: pointer;
				transition:
					transform var(--transition),
					background-color var(--transition),
					border-color var(--transition),
					color var(--transition);
			}

			.prose :global(.code-expand:hover) {
				transform: translateY(-1px);
				background: rgba(239, 247, 242, 0.14);
				border-color: rgba(239, 247, 242, 0.16);
			}

			.prose :global(.code-actions) {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				flex-wrap: wrap;
				justify-content: flex-end;
				margin-left: auto;
			}

			.prose :global(.code-block.collapsed pre) {
				max-height: 22rem;
				overflow: hidden;
			}

			.prose :global(.code-block.collapsed pre::after) {
				content: '';
				position: absolute;
				right: 0;
				bottom: 0;
				left: 0;
				height: 6rem;
				background: linear-gradient(180deg, rgba(18, 29, 23, 0), rgba(18, 29, 23, 0.98));
				pointer-events: none;
			}

			.prose :global(pre.mermaid) {
				position: relative;
				display: block;
				width: auto;
				max-width: 100%;
				margin: 1.6rem 0;
				padding: 1rem 1.1rem;
				overflow-x: auto;
				border-radius: 18px;
				background: var(--mermaid-bg);
				border: 1px solid rgba(93, 154, 121, 0.14);
				box-shadow: 0 14px 32px rgba(43, 38, 30, 0.08);
				white-space: normal;
			}

			.prose :global(pre.mermaid)::before {
				content: 'Mermaid';
				display: inline-flex;
				align-items: center;
				margin-bottom: 0.95rem;
				padding: 0.34rem 0.62rem;
				border-radius: 999px;
				background: rgba(93, 154, 121, 0.1);
				border: 1px solid rgba(93, 154, 121, 0.12);
				color: var(--accent-strong);
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.prose :global(pre.mermaid svg) {
				display: block;
				width: auto !important;
				max-width: 100%;
				height: auto;
				margin: 0;
			}

			.prose :global(pre.mermaid[data-render-error='true']) {
				padding-bottom: 1.1rem;
				color: var(--ink-soft);
				font-size: 0.94rem;
				line-height: 1.8;
			}

			.prose :global(pre:not(.mermaid) code) {
				display: block;
				color: rgba(239, 247, 242, 0.92);
				font-size: 0.92rem;
				line-height: 1.75;
			}

			.prose :global(:not(pre) > code) {
				padding: 0.2rem 0.46rem;
				border-radius: 0.5rem;
				background: rgba(93, 154, 121, 0.12);
				border: 1px solid rgba(93, 154, 121, 0.1);
				color: var(--accent-strong);
				font-size: 0.88em;
			}

			.prose :global(blockquote) {
				position: relative;
				margin: 1.7rem 0;
				padding: 1.2rem 1.25rem 1.2rem 1.35rem;
				border-left: 0;
				border-radius: 16px;
				background:
					linear-gradient(180deg, rgba(255, 248, 240, 0.9), rgba(255, 252, 247, 0.78));
				border: 1px solid rgba(226, 168, 111, 0.18);
				box-shadow: 0 10px 24px rgba(226, 168, 111, 0.08);
			}

			.prose :global(blockquote)::before {
				content: '“';
				position: absolute;
				top: 0.55rem;
				left: 0.85rem;
				font-family: var(--font-display);
				font-size: 2.1rem;
				line-height: 1;
				color: rgba(226, 168, 111, 0.55);
			}

			.prose :global(blockquote > :first-child) {
				margin-top: 0;
			}

			.prose :global(blockquote > :last-child) {
				margin-bottom: 0;
			}

			.prose :global(hr) {
				margin: 2.6rem 0 2.2rem;
				height: 1px;
				background: linear-gradient(90deg, transparent, rgba(93, 154, 121, 0.4), transparent);
			}

			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				overflow: hidden;
				border-radius: 14px;
				border: 1px solid rgba(116, 108, 94, 0.12);
				box-shadow: 0 10px 24px rgba(43, 38, 30, 0.05);
				background: rgba(255, 253, 249, 0.85);
			}

			.prose :global(th),
			.prose :global(td) {
				padding: 0.8rem 0.95rem;
				text-align: left;
				border-bottom: 1px solid rgba(116, 108, 94, 0.1);
			}

			.prose :global(th) {
				font-size: 0.86rem;
				font-weight: 800;
				color: var(--ink);
				background: rgba(93, 154, 121, 0.08);
			}

			.prose :global(tr:last-child td) {
				border-bottom: 0;
			}

			.prose :global(figure) {
				margin: 1.8rem 0;
			}

			.prose :global(figcaption) {
				margin-top: 0.7rem;
				font-size: 0.86rem;
				text-align: center;
				color: var(--ink-faint);
			}

			.prose :global(strong) {
				color: var(--ink);
			}

			html[data-theme='dark'] .progress {
				background: rgba(17, 25, 21, 0.88);
				border-color: rgba(141, 172, 151, 0.18);
				box-shadow: 0 22px 44px rgba(0, 0, 0, 0.28);
			}

			html[data-theme='dark'] .progress-track {
				background:
					linear-gradient(90deg, rgba(120, 195, 151, 0.12), rgba(239, 180, 126, 0.16)),
					rgba(255, 255, 255, 0.04);
				border-color: rgba(141, 172, 151, 0.14);
			}

			html[data-theme='dark'] .progress-chip {
				background: rgba(237, 246, 239, 0.1);
				color: var(--ink);
				border: 1px solid rgba(141, 172, 151, 0.14);
			}

			html[data-theme='dark'] .progress-toggle {
				background: rgba(237, 246, 239, 0.08);
				color: var(--ink-faint);
			}

			html[data-theme='dark'] .prose :global(blockquote) {
				background: linear-gradient(180deg, rgba(38, 29, 21, 0.68), rgba(18, 29, 23, 0.86));
				border-color: rgba(239, 180, 126, 0.16);
			}

			html[data-theme='dark'] .prose :global(table) {
				background: rgba(18, 29, 23, 0.88);
				border-color: rgba(141, 172, 151, 0.14);
			}

			html[data-theme='dark'] .prose :global(th),
			html[data-theme='dark'] .prose :global(td) {
				border-bottom-color: rgba(141, 172, 151, 0.12);
			}

			html[data-theme='dark'] .prose :global(th) {
				background: rgba(120, 195, 151, 0.1);
			}

			html[data-theme='dark'] .prose :global(pre.mermaid) {
				background: linear-gradient(180deg, rgba(18, 29, 23, 0.96), rgba(16, 24, 20, 0.94));
				border-color: rgba(141, 172, 151, 0.18);
			}

			html[data-theme='dark'] .prose :global(pre.mermaid)::before {
				background: rgba(120, 195, 151, 0.12);
				border-color: rgba(141, 172, 151, 0.16);
				color: var(--accent-strong);
			}

			html[data-theme='dark'] .toc-list::before {
				box-shadow: 0 0 16px rgba(120, 195, 151, 0.22);
			}

			html[data-theme='dark'] .toc-link.active {
				background: linear-gradient(90deg, rgba(120, 195, 151, 0.14), rgba(120, 195, 151, 0.04));
			}

			.article-toc {
				position: sticky;
				top: 6.1rem;
				display: grid;
				gap: 0.45rem;
				align-self: start;
				padding: 0.35rem 0 0 0;
				background: transparent;
				border: 0;
				box-shadow: none;
				backdrop-filter: none;
			}

			.toc-list {
				position: relative;
				display: grid;
				gap: 0.35rem;
				padding-left: 0.85rem;
				border-left: 1px solid var(--line);
			}

			.toc-list::before {
				content: '';
				position: absolute;
				left: -1px;
				top: var(--toc-indicator-top, 0px);
				width: 2px;
				height: var(--toc-indicator-height, 0px);
				border-radius: 999px;
				background: linear-gradient(180deg, var(--accent-warm), var(--accent));
				box-shadow: 0 0 14px rgba(93, 154, 121, 0.16);
				opacity: var(--toc-indicator-opacity, 0);
				transition:
					top 220ms var(--transition),
					height 220ms var(--transition),
					opacity 220ms var(--transition);
			}

			.toc-link {
				justify-content: start;
				width: 100%;
				text-align: left;
				padding: 0.58rem 0.72rem 0.58rem 0.55rem;
				border-radius: 12px;
				border: 0;
				background: transparent;
				box-shadow: none;
				font-weight: 600;
				font-size: 0.88rem;
				line-height: 1.35;
				transform-origin: left center;
			}

			.toc-link.active {
				color: var(--accent-strong);
				background: linear-gradient(90deg, rgba(93, 154, 121, 0.12), rgba(93, 154, 121, 0.03));
				transform: translateX(4px);
			}

			.toc-link.depth-3 {
				padding-left: 1.35rem;
				font-size: 0.82rem;
				color: var(--ink-faint);
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1.2rem;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.top-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 0.9rem;
				padding: 0.76rem 0.95rem;
				border-radius: 999px;
				background: transparent;
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.article-nav {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.nav-card {
				display: grid;
				gap: 0.65rem;
				padding: var(--space-4);
				background: var(--card-bg-warm);
				border: 1px solid var(--line);
				border-radius: 12px;
				box-shadow: var(--shadow-sm);
			}

			.image-lightbox {
				position: fixed;
				inset: 0;
				display: none;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				background: rgba(0, 0, 0, 0.72);
				z-index: 120;
			}

			.image-lightbox.open {
				display: flex;
			}

			.image-lightbox img {
				max-width: min(1100px, 100%);
				max-height: 86vh;
				border-radius: 12px;
			}

			.nav-card span {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}

			.nav-card h3 {
				font-size: 1.18rem;
				line-height: 1.18;
			}

			@media (max-width: 960px) {
				.article-content.has-toc,
				.article-nav {
					grid-template-columns: 1fr;
				}

				.article-toc {
					position: static;
					order: -1;
					padding-top: 0;
				}
			}

			@media (max-width: 720px) {
				main {
					width: min(calc(100% - 1rem), 1180px);
				}

				.progress {
					width: 100%;
				}

				.article-hero,
				.hero-media,
				.article-body,
				.article-toc,
				.article-nav {
					padding: var(--space-4);
				}

				.article-hero h1 {
					font-size: clamp(1.75rem, 8vw, 2.35rem);
					max-width: none;
				}

				.meta-row {
					gap: 0.5rem;
				}

				.meta-pill,
				.meta-button,
				.category-pill {
					font-size: 0.8rem;
					padding: 0.58rem 0.72rem;
				}

				.prose {
					font-size: 0.98rem;
					line-height: 1.82;
				}

				.prose :global(h2) {
					margin-top: 2rem;
				}

				.prose :global(.code-toolbar) {
					right: 0.85rem;
					gap: 0.5rem;
				}

				.prose :global(.code-language),
				.prose :global(.code-copy) {
					font-size: 0.68rem;
				}

				.progress-section-title {
					font-size: 0.8rem;
				}
			}
		</style>
	</head>
	<body>
		<Header>
			<div class="progress collapsed" aria-live="polite" data-reading-time={readingTime}>
				<div class="progress-topline">
					<span class="progress-label">阅读进度</span>
					<div style="display:flex;align-items:center;gap:.45rem;">
						<span class="progress-badge" data-progress-badge>0%</span>
						<button class="progress-toggle" type="button" aria-label="切换阅读进度显示" data-progress-toggle>展开</button>
					</div>
				</div>
				<div class="progress-track" aria-hidden="true">
					<div class="progress-fill"></div>
				</div>
				<div class="progress-meta">
					<div class="progress-section">
						<span class="progress-section-title" data-progress-section>正在阅读正文</span>
						<span class="progress-section-subtitle" data-progress-subtitle>跟着当前章节继续往下读</span>
					</div>
					<span class="progress-chip" data-progress-eta>剩余约 {readingTime} 分钟</span>
				</div>
			</div>
		</Header>
		<main>
			<article class="article-shell">
				<header class="article-hero soft-panel">
					<span class="section-tag">文章</span>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="meta-row">
						<a class="category-pill" href={`${import.meta.env.BASE_URL}blog#${toCategoryId(category)}`}>{category}</a>
						<span class="meta-pill"><FormattedDate date={pubDate} /></span>
						<span class="meta-pill">约 {readingTime} 分钟</span>
						<button class="meta-button" type="button" data-copy-link>复制链接</button>
						{updatedDate && <span class="meta-pill">更新于 <FormattedDate date={updatedDate} /></span>}
					</div>
					{categorySummary && <p>{categorySummary}</p>}
				</header>

				{heroImage && (
					<div class="hero-media soft-panel">
						<Image width={1400} height={800} src={heroImage} alt={title} />
					</div>
				)}

				<div class:list={['article-content', { 'has-toc': tocItems.length > 0 }]}>
					{tocItems.length > 0 && (
						<aside class="article-toc soft-panel">
							<div class="toc-list">
								{tocItems.map((heading) => (
									<a class={`toc-link depth-${heading.depth}`} href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
								))}
							</div>
						</aside>
					)}

					<div class="article-body soft-panel">
						<div class="prose">
							<slot />
						</div>
						<a href={`${import.meta.env.BASE_URL}blog`} class="back-link">返回文章列表</a>
						<a href="#top" class="top-link" data-top-link>回到顶部</a>
					</div>
				</div>

				{(previousPost || nextPost) && (
					<section class="article-nav soft-panel">
						{previousPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${previousPost.id}/`}>
								<span>上一篇</span>
								<h3>{previousPost.data.title}</h3>
								<p>{previousPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
						{nextPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${nextPost.id}/`}>
								<span>下一篇</span>
								<h3>{nextPost.data.title}</h3>
								<p>{nextPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
					</section>
				)}
			</article>
		</main>
		<Footer />
		<div class="image-lightbox" data-lightbox>
			<img alt="" data-lightbox-image />
		</div>
		<script>
			import mermaid from 'mermaid';

			const copyButton = document.querySelector('[data-copy-link]');
			if (copyButton) {
				copyButton.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(window.location.href);
						window.showToast?.('链接已复制');
					} catch {
						window.showToast?.('复制失败');
					}
				});
			}

			const progress = document.querySelector('.progress');
			const progressBadge = document.querySelector('[data-progress-badge]');
			const progressToggle = document.querySelector('[data-progress-toggle]');
			const progressSection = document.querySelector('[data-progress-section]');
			const progressSubtitle = document.querySelector('[data-progress-subtitle]');
			const progressEta = document.querySelector('[data-progress-eta]');
			const articleBody = document.querySelector('.article-body');
			const contentHeadings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));

			const totalReadingMinutes = Math.max(
				1,
				Number.parseInt(progress?.getAttribute('data-reading-time') || '1', 10) || 1,
			);
			const updateCurrentSection = () => {
				if (!progressSection || !progressSubtitle) return;

				const currentHeading = contentHeadings.reduce((activeHeading, heading) => {
					const rect = heading.getBoundingClientRect();
					if (rect.top <= window.innerHeight * 0.28) {
						return heading;
					}
					return activeHeading;
				}, null);

				if (!currentHeading) {
					progressSection.textContent = '正在阅读正文';
					progressSubtitle.textContent = '跟着当前章节继续往下读';
					return;
				}

				progressSection.textContent = currentHeading.textContent?.trim() || '正在阅读正文';
				progressSubtitle.textContent = currentHeading.tagName === 'H2' ? '当前主章节' : '当前小节';
			};

			const updateProgress = () => {
				if (!progress) return;
				const articleRect = articleBody?.getBoundingClientRect();
				const articleTop = articleRect ? window.scrollY + articleRect.top : 0;
				const articleHeight = articleBody?.scrollHeight || document.documentElement.scrollHeight;
				const max = Math.max(1, articleHeight - window.innerHeight * 0.72);
				const scrollTop = Math.max(0, window.scrollY - articleTop + window.innerHeight * 0.2);
				const ratio = max <= 0 ? 0 : Math.min(1, Math.max(0, scrollTop / max));
				const percent = `${Math.round(ratio * 100)}%`;
				progress.style.setProperty('--progress', `${(ratio * 100).toFixed(2)}%`);
				progress.classList.toggle('engaged', ratio > 0.03);
				if (progressBadge) progressBadge.textContent = percent;
				if (progressEta) {
					const remainingMinutes = Math.max(0, Math.ceil(totalReadingMinutes * (1 - ratio)));
					progressEta.textContent = remainingMinutes > 0 ? `剩余约 ${remainingMinutes} 分钟` : '已读完正文';
				}
				updateCurrentSection();
			};
			window.addEventListener('scroll', updateProgress, { passive: true });
			window.addEventListener('resize', updateProgress);
			updateProgress();

			progressToggle?.addEventListener('click', () => {
				if (!progress) return;
				const collapsed = progress.classList.toggle('collapsed');
				progressToggle.textContent = collapsed ? '展开' : '收起';
			});

			const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
			const headingTargets = tocLinks
				.map((link) => {
					const slug = link.getAttribute('data-toc-link');
					const target = slug ? document.getElementById(slug) : null;
					return target ? { link, target } : null;
				})
				.filter(Boolean);

			if (headingTargets.length > 0) {
				const updateTocIndicator = (activeLink) => {
					if (!activeLink) return;
					const tocList = activeLink.closest('.toc-list');
					if (!tocList) return;
					tocList.style.setProperty('--toc-indicator-top', `${activeLink.offsetTop}px`);
					tocList.style.setProperty('--toc-indicator-height', `${activeLink.offsetHeight}px`);
					tocList.style.setProperty('--toc-indicator-opacity', '1');
				};

				const activateLink = (id) => {
					headingTargets.forEach(({ link, target }) => {
						link.classList.toggle('active', target.id === id);
					});
					const activeLink = headingTargets.find(({ target }) => target.id === id)?.link;
					if (activeLink) {
						updateTocIndicator(activeLink);
						// Scroll TOC container only, avoid hijacking page scroll
						const tocContainer = tocList?.parentElement;
						if (tocContainer && tocContainer.scrollHeight > tocContainer.clientHeight) {
							const linkTop = activeLink.offsetTop;
							const containerHeight = tocContainer.clientHeight;
							tocContainer.scrollTop = linkTop - containerHeight / 2 + activeLink.offsetHeight / 2;
						}
					}
				};

				const observer = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
						if (visible[0]?.target?.id) {
							activateLink(visible[0].target.id);
						}
					},
					{
						rootMargin: '-20% 0px -65% 0px',
						threshold: [0, 1],
					},
				);

				headingTargets.forEach(({ target }) => observer.observe(target));
				activateLink(headingTargets[0].target.id);
			}

			const formatLanguageLabel = (rawLanguage) => {
				if (!rawLanguage) return 'TEXT';

				const normalized = rawLanguage.toLowerCase();
				const labels = {
					js: 'JavaScript',
					javascript: 'JavaScript',
					ts: 'TypeScript',
					typescript: 'TypeScript',
					tsx: 'TSX',
					jsx: 'JSX',
					html: 'HTML',
					css: 'CSS',
					scss: 'SCSS',
					bash: 'Bash',
					shell: 'Shell',
					sh: 'Shell',
					json: 'JSON',
					yaml: 'YAML',
					yml: 'YAML',
					md: 'Markdown',
					markdown: 'Markdown',
					java: 'Java',
					python: 'Python',
					py: 'Python',
					go: 'Go',
					rust: 'Rust',
					text: 'Text',
					txt: 'Text',
				};

				return labels[normalized] || rawLanguage.toUpperCase();
			};

			const mermaidBlocks = Array.from(document.querySelectorAll('.prose pre.mermaid'));
			let mermaidReady = false;
			const renderMermaid = async () => {
				if (mermaidBlocks.length === 0) return;

				if (!mermaidReady) {
					mermaid.initialize({
						startOnLoad: false,
						theme: 'default',
						securityLevel: 'loose',
					});
					mermaidReady = true;
				}

				for (const block of mermaidBlocks) {
					block.dataset.mermaidSource ||= block.textContent || '';
					block.innerHTML = block.dataset.mermaidSource;
					block.removeAttribute('data-processed');
					block.removeAttribute('data-render-error');
				}

				try {
					await mermaid.run({ nodes: mermaidBlocks });
					for (const block of mermaidBlocks) {
						const svg = block.querySelector('svg');
						const viewBox = svg?.getAttribute('viewBox')?.split(/\s+/).map(Number);
						const proseWidth = block.parentElement?.clientWidth || 704;
						const minWidth = Math.min(360, proseWidth);
						const fallbackWidth = Math.min(Math.max(proseWidth * 0.72, minWidth), proseWidth);

						if (svg && viewBox && viewBox.length === 4 && Number.isFinite(viewBox[2])) {
							const fittedWidth = Math.min(Math.max(viewBox[2] + 40, minWidth), proseWidth);
							block.style.width = `${fittedWidth}px`;
						} else {
							block.style.width = `${fallbackWidth}px`;
						}
					}
				} catch {
					mermaidBlocks.forEach((block) => {
						block.dataset.renderError = 'true';
					});
					window.showToast?.('Mermaid 渲染失败，请检查语法');
				}
			};

			void renderMermaid();

			const codeBlocks = Array.from(document.querySelectorAll('.prose pre:not(.mermaid)'));
			codeBlocks.forEach((pre) => {
				const code = pre.querySelector('code');
				if (!code || pre.parentElement?.classList.contains('code-block')) return;

				const language = pre.getAttribute('data-language') || 'text';

				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.parentNode?.insertBefore(wrapper, pre);

				const toolbar = document.createElement('div');
				toolbar.className = 'code-toolbar';

				const languageLabel = document.createElement('span');
				languageLabel.className = 'code-language';
				languageLabel.textContent = formatLanguageLabel(language);

				const copyCodeButton = document.createElement('button');
				copyCodeButton.className = 'code-copy';
				copyCodeButton.type = 'button';
				copyCodeButton.textContent = '复制代码';

				const actions = document.createElement('div');
				actions.className = 'code-actions';

				copyCodeButton.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(code.textContent || '');
						copyCodeButton.textContent = '已复制';
						window.showToast?.('代码已复制');
						window.setTimeout(() => {
							copyCodeButton.textContent = '复制代码';
						}, 1800);
					} catch {
						copyCodeButton.textContent = '复制失败';
						window.setTimeout(() => {
							copyCodeButton.textContent = '复制代码';
						}, 1800);
						window.showToast?.('复制失败');
					}
				});

				const lineCount = (code.textContent || '').split('\n').length;
				if (lineCount > 16) {
					wrapper.classList.add('collapsed');
					const expandButton = document.createElement('button');
					expandButton.className = 'code-expand';
					expandButton.type = 'button';
					expandButton.textContent = '展开代码';
					expandButton.addEventListener('click', () => {
						const collapsed = wrapper.classList.toggle('collapsed');
						expandButton.textContent = collapsed ? '展开代码' : '收起代码';
					});
					actions.appendChild(expandButton);
				}

				actions.appendChild(copyCodeButton);
				toolbar.append(languageLabel, actions);
				wrapper.append(toolbar, pre);
			});

			const proseImages = Array.from(document.querySelectorAll('.prose img'));
			const lightbox = document.querySelector('[data-lightbox]');
			const lightboxImage = document.querySelector('[data-lightbox-image]');
			const topLink = document.querySelector('[data-top-link]');

			topLink?.addEventListener('click', (event) => {
				event.preventDefault();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			proseImages.forEach((image) => {
				image.addEventListener('click', () => {
					if (!lightbox || !lightboxImage) return;
					lightboxImage.src = image.currentSrc || image.src;
					lightboxImage.alt = image.alt || '';
					lightbox.classList.add('open');
				});
			});

			lightbox?.addEventListener('click', () => {
				lightbox.classList.remove('open');
			});

			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					lightbox?.classList.remove('open');
				}
			});
		</script>
	</body>
</html>
