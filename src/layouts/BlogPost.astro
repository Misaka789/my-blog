---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CategorizedPost } from '../data/categories';
import { toCategoryId } from '../data/categories';

type TocHeading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	category: string;
	categorySummary?: string;
	headings?: TocHeading[];
	readingTime?: number;
	previousPost?: CategorizedPost;
	nextPost?: CategorizedPost;
	relatedPosts?: CategorizedPost[];
};

const {
	title,
	description,
	category,
	pubDate,
	updatedDate,
	heroImage,
	categorySummary = '',
	headings = [],
	readingTime = 1,
	previousPost,
	nextPost,
	relatedPosts = [],
} = Astro.props;

const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(calc(100% - 2rem), 1180px);
			}

			.progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 100%;
				background: transparent;
				z-index: 90;
			}

			.progress::after {
				content: '';
				display: block;
				height: 100%;
				width: var(--progress, 0%);
				background: linear-gradient(90deg, var(--accent), var(--accent-strong));
				transition: width 100ms linear;
			}

			.article-shell {
				display: grid;
				gap: var(--space-4);
				padding-top: var(--space-4);
			}

			.article-hero,
			.hero-media,
			.article-body,
			.article-toc,
			.article-nav,
			.related-section {
				padding: var(--space-5);
			}

			.article-hero {
				display: grid;
				gap: var(--space-3);
			}

			.article-hero h1 {
				max-width: 18ch;
			}

			.article-hero p {
				max-width: 46rem;
			}

			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.meta-pill,
			.meta-button,
			.category-pill,
			.toc-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.72rem 0.92rem;
				border-radius: 999px;
				background: #fff;
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
				font-size: 0.9rem;
			}

			.meta-button {
				cursor: pointer;
			}

			.category-pill:hover,
			.meta-button:hover,
			.back-link:hover,
			.nav-card:hover,
			.related-card:hover,
			.toc-link:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-sm);
				color: var(--ink);
			}

			.hero-media :global(img) {
				width: 100%;
				object-fit: cover;
				border-radius: calc(var(--radius-xl) - 8px);
			}

			.article-content {
				display: grid;
				grid-template-columns: minmax(0, 1fr);
				gap: var(--space-3);
				align-items: start;
			}

			.article-content.has-toc {
				grid-template-columns: minmax(0, 1fr) 270px;
			}

			.prose {
				display: grid;
				gap: 1rem;
			}

			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				scroll-margin-top: 6rem;
			}

			.prose :global(h2) {
				margin-top: 2rem;
			}

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol),
			.prose :global(blockquote) {
				max-width: 42rem;
			}

			.prose :global(a) {
				color: var(--accent-strong);
				text-decoration: underline;
				text-decoration-color: rgba(104, 134, 111, 0.35);
				text-underline-offset: 0.18em;
			}

			.article-toc {
				position: sticky;
				top: 6.1rem;
				display: grid;
				gap: 0.9rem;
			}

			.toc-list {
				display: grid;
				gap: 0.65rem;
			}

			.toc-link {
				justify-content: start;
				width: 100%;
				text-align: left;
			}

			.toc-link.depth-3 {
				padding-left: 1.18rem;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1.2rem;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				background: #fff;
				border: 1px solid var(--line);
				color: var(--ink-soft);
				font-weight: 700;
			}

			.article-nav {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.nav-card,
			.related-card {
				display: grid;
				gap: 0.65rem;
				padding: var(--space-4);
				background: var(--paper-strong);
				border: 1px solid var(--line);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-sm);
			}

			.nav-card span,
			.related-card span {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}

			.related-section {
				display: grid;
				gap: var(--space-3);
			}

			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: var(--space-3);
			}

			.related-card h3,
			.nav-card h3 {
				font-size: 1.18rem;
				line-height: 1.18;
			}

			.post-meta {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--ink-faint);
			}

			.post-meta::before {
				content: '';
				width: 0.42rem;
				height: 0.42rem;
				border-radius: 999px;
				background: var(--accent-warm);
			}

			.section-head {
				display: grid;
				gap: 0.75rem;
			}

			@media (max-width: 960px) {
				.article-content.has-toc,
				.article-nav,
				.related-grid {
					grid-template-columns: 1fr;
				}

				.article-toc {
					position: static;
					order: -1;
				}
			}

			@media (max-width: 720px) {
				main {
					width: min(calc(100% - 1rem), 1180px);
				}

				.article-hero,
				.hero-media,
				.article-body,
				.article-toc,
				.article-nav,
				.related-section {
					padding: var(--space-4);
				}
			}
		</style>
	</head>
	<body>
		<div class="progress" aria-hidden="true"></div>
		<Header />
		<main>
			<article class="article-shell">
				<header class="article-hero soft-panel">
					<span class="section-tag">文章</span>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="meta-row">
						<a class="category-pill" href={`${import.meta.env.BASE_URL}blog#${toCategoryId(category)}`}>{category}</a>
						<span class="meta-pill"><FormattedDate date={pubDate} /></span>
						<span class="meta-pill">约 {readingTime} 分钟</span>
						<button class="meta-button" type="button" data-copy-link>复制链接</button>
						{updatedDate && <span class="meta-pill">更新于 <FormattedDate date={updatedDate} /></span>}
					</div>
					{categorySummary && <p>{categorySummary}</p>}
				</header>

				{heroImage && (
					<div class="hero-media soft-panel">
						<Image width={1400} height={800} src={heroImage} alt={title} />
					</div>
				)}

				<div class:list={['article-content', { 'has-toc': tocItems.length > 0 }]}>
					<div class="article-body soft-panel">
						<div class="prose">
							<slot />
						</div>
						<a href={`${import.meta.env.BASE_URL}blog`} class="back-link">返回文章归档</a>
					</div>

					{tocItems.length > 0 && (
						<aside class="article-toc soft-panel">
							<div class="section-head">
								<span class="section-tag">目录</span>
								<h2>这篇文章会讲什么</h2>
							</div>
							<div class="toc-list">
								{tocItems.map((heading) => (
									<a class={`toc-link depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
								))}
							</div>
						</aside>
					)}
				</div>

				{(previousPost || nextPost) && (
					<section class="article-nav soft-panel">
						{previousPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${previousPost.id}/`}>
								<span>上一篇</span>
								<h3>{previousPost.data.title}</h3>
								<p>{previousPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
						{nextPost ? (
							<a class="nav-card" href={`${import.meta.env.BASE_URL}blog/${nextPost.id}/`}>
								<span>下一篇</span>
								<h3>{nextPost.data.title}</h3>
								<p>{nextPost.categoryName}</p>
							</a>
						) : (
							<div />
						)}
					</section>
				)}

				{relatedPosts.length > 0 && (
					<section class="related-section soft-panel">
						<div class="section-head">
							<span class="section-tag">继续阅读</span>
							<h2>接着看看这些文章</h2>
							<p>如果这篇对你有帮助，下面这些内容大概率也会相关。</p>
						</div>
						<div class="related-grid">
							{relatedPosts.map((post) => (
								<a class="related-card" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
									<span>{post.categoryName}</span>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<div class="post-meta"><FormattedDate date={post.data.pubDate} /></div>
								</a>
							))}
						</div>
					</section>
				)}
			</article>
		</main>
		<Footer />
		<script>
			const copyButton = document.querySelector('[data-copy-link]');
			if (copyButton) {
				copyButton.addEventListener('click', async () => {
					const originalText = copyButton.textContent;
					try {
						await navigator.clipboard.writeText(window.location.href);
						copyButton.textContent = '链接已复制';
					} catch {
						copyButton.textContent = '复制失败';
					}
					window.setTimeout(() => {
						copyButton.textContent = originalText;
					}, 1200);
				});
			}

			const progress = document.querySelector('.progress');
			const updateProgress = () => {
				if (!progress) return;
				const scrollTop = window.scrollY;
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const ratio = max <= 0 ? 0 : Math.min(1, Math.max(0, scrollTop / max));
				progress.style.setProperty('--progress', `${(ratio * 100).toFixed(2)}%`);
			};
			window.addEventListener('scroll', updateProgress, { passive: true });
			updateProgress();
		</script>
	</body>
</html>
